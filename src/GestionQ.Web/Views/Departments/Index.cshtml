@model IEnumerable<GestionQ.Domain.Entities.Department>

@{
    ViewData["Title"] = "Gestión de Departamentos";
}

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <h1 class="page-title" style="margin: 0;">Gestión de Departamentos</h1>
    <a asp-action="Create" class="btn-primary">Nuevo Departamento</a>
</div>

@if (TempData["Error"] != null)
{
    <div class="glass-panel" style="background: rgba(239, 68, 68, 0.1); border-color: rgba(239, 68, 68, 0.2); color: #ef4444; margin-bottom: 1rem;">
        @TempData["Error"]
    </div>
}

<div class="glass-panel">
    <table class="table">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Tecla Rápida</th>
                <th>Alícuota IVA</th>
                <th>Código Virtual</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td style="font-weight: 600;">@item.Name</td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.Hotkey))
                        {
                            <span class="badge" style="background: rgba(16, 185, 129, 0.1); color: #10b981; font-weight: bold; padding: 0.25rem 0.5rem; border-radius: 4px;">@item.Hotkey</span>
                        }
                        else
                        {
                            <span style="color: #64748b; font-style: italic;">Ninguna</span>
                        }
                    </td>
                    <td>@(item.VatRate?.Rate.ToString("N1") ?? "0.0")%</td>
                    <td>@(item.VirtualProduct?.InternalCode.ToString("D5") ?? "-")</td>
                    <td>
                        <div style="display: flex; gap: 0.5rem;">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn-secondary" style="padding: 0.25rem 0.75rem; font-size: 0.85rem;">Editar</a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('¿Está seguro de eliminar este departamento?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-secondary" style="padding: 0.25rem 0.75rem; font-size: 0.85rem; color: #ef4444; border: none; background: none; cursor: pointer;">Eliminar</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="5" style="text-align: center; color: #64748b; font-style: italic; padding: 2rem;">No hay departamentos configurados.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
