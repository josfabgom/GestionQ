@model GestionQ.Web.Models.ProductViewModel

@{
    ViewData["Title"] = "Nuevo Producto";
}

<h1 class="page-title">Nuevo Producto</h1>

<div class="glass-panel" style="max-width: 900px;">
    <form asp-action="Create" enctype="multipart/form-data">
        <div style="display: grid; grid-template-columns: 1fr 300px; gap: 2rem;">
            <!-- Left Column: Form Fields -->
            <div>
                <div class="form-group" style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem;">
                    <input asp-for="IsActive" style="width: 20px; height: 20px;" checked />
                    <label asp-for="IsActive" style="margin: 0; font-weight: 600;">Habilitado para la venta</label>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="form-group">
                        <label asp-for="InternalCode" class="control-label"></label>
                        <input asp-for="InternalCode" class="form-control" readonly placeholder="[Automático]" />
                    </div>
                    <div class="form-group">
                        <label asp-for="Barcode" class="control-label"></label>
                        <input asp-for="Barcode" class="form-control" />
                        <span asp-validation-for="Barcode" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="Name" class="control-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="form-group">
                        <label class="control-label">Rubro</label>
                        <select id="CategoryId" class="form-control">
                            <option value="">Seleccione...</option>
                            @if (ViewBag.Categories != null)
                            {
                                foreach (var cat in ViewBag.Categories as IEnumerable<GestionQ.Domain.Entities.Category>)
                                {
                                    if (ViewBag.SelectedCategoryId != null && (int)ViewBag.SelectedCategoryId == cat.Id)
                                    {
                                        <option value="@cat.Id" selected>@cat.Name</option>
                                    }
                                    else
                                    {
                                        <option value="@cat.Id">@cat.Name</option>
                                    }
                                }
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label asp-for="SubCategoryId" class="control-label"></label>
                        <select asp-for="SubCategoryId" class="form-control" id="SubCategoryId" required>
                            <option value="">Primero seleccione rubro</option>
                        </select>
                        <span asp-validation-for="SubCategoryId" class="text-danger"></span>
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="form-group">
                        <label asp-for="IsPesable" class="control-label"></label>
                        <select asp-for="IsPesable" class="form-control">
                            <option value="false">Unidad</option>
                            <option value="true">Pesable</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label asp-for="SendToScale" class="control-label"></label>
                        <select asp-for="SendToScale" class="form-control">
                            <option value="false">NO</option>
                            <option value="true">SI</option>
                        </select>
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="form-group">
                        <label asp-for="Stock" class="control-label">Stock Actual</label>
                        <input asp-for="Stock" type="number" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label asp-for="MinimumStock" class="control-label">Stock Mínimo</label>
                        <input asp-for="MinimumStock" type="number" class="form-control" />
                        <span asp-validation-for="MinimumStock" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="Price" class="control-label">Precio de Venta Final ($)</label>
                    <div style="display: flex; gap: 0.5rem; align-items: stretch;">
                        <input asp-for="Price" type="number" class="form-control" id="Price" style="background: rgba(96, 165, 250, 0.15); border-color: var(--accent); font-weight: 700; font-size: 1.5rem; color: #fff; flex: 1;" step="0.01" />
                        <button type="button" class="btn-secondary" onclick="openPriceWizard()" style="padding: 0 1rem; white-space: nowrap;" title="Calcular desde Costos">
                            ⚙️ Estructura
                        </button>
                    </div>
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

                <!-- Hidden inputs to preserve model binding -->
                <input type="hidden" asp-for="VatRateId" id="VatRateId" />
                <input type="hidden" name="BaseCost" id="BaseCost" value="@Model.BaseCost.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)" />
                <input type="hidden" name="ProfitMargin" id="ProfitMargin" value="@Model.ProfitMargin.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)" />
                <input type="hidden" name="InternalTax" id="InternalTax" value="@Model.InternalTax.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)" />
            </div>

            <!-- Right Column: Image Upload -->
            <div>
                <label class="control-label">Imagen del Producto</label>
                <div style="border: 2px dashed var(--border); border-radius: 12px; padding: 1rem; text-align: center; background: rgba(255,255,255,0.02);">
                    <div id="imagePreview" style="width: 100%; aspect-ratio: 1; border-radius: 8px; overflow: hidden; margin-bottom: 1rem; display: flex; align-items: center; justify-content: center; background: rgba(0,0,0,0.2);">
                        <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" style="opacity: 0.2;">
                            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                            <circle cx="8.5" cy="8.5" r="1.5"></circle>
                            <polyline points="21 15 16 10 5 21"></polyline>
                        </svg>
                    </div>
                    <input type="file" asp-for="ImageFile" id="imageInput" style="display: none;" accept="image/*" />
                    <button type="button" onclick="document.getElementById('imageInput').click()" class="btn-secondary" style="width: 100%;">Seleccionar Imagen</button>
                    <p style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.5rem;">Formatos: JPG, PNG. Máx 2MB.</p>
                </div>
            </div>
        </div>

        <div class="form-group" style="margin-top: 2rem; border-top: 1px solid var(--border); padding-top: 1.5rem; display: flex; gap: 1rem;">
            <input type="submit" value="Guardar Producto" class="btn-primary" />
            <a asp-action="Index" class="btn-secondary">Volver</a>
        </div>
    </form>
</div>

<!-- Price Structure Wizard Modal -->
<div id="priceWizard" class="modal-overlay" style="display: none;">
    <div class="glass-panel modal-content" style="max-width: 500px; width: 90%;">
        <h2 class="page-title">Estructura de Precio</h2>
        <p style="opacity: 0.7; margin-bottom: 2rem;">Configure los costos y márgenes para calcular el precio final automáticamente.</p>
        
        <div class="form-group">
            <label class="control-label">Alícuota IVA</label>
            <select id="WizardVatRateId" class="form-control" onchange="calculateWizard()">
                <option value="" data-rate="0">Seleccione...</option>
                @foreach (var v in ViewBag.VatRates as IEnumerable<GestionQ.Domain.Entities.VatRate>)
                {
                    <option value="@v.Id" data-rate="@v.Rate">@v.Name (@v.Rate%)</option>
                }
            </select>
        </div>

        <div class="form-group">
            <label class="control-label">Costo Base ($)</label>
            <input type="number" id="WizardBaseCost" class="form-control" step="0.01" value="0.00" oninput="calculateWizard()" />
        </div>

        <div class="form-group">
            <label class="control-label">Margen de Ganancia (%)</label>
            <input type="number" id="WizardProfitMargin" class="form-control" step="0.1" value="0.0" oninput="calculateWizard()" />
        </div>

        <div class="form-group">
            <label class="control-label">Impuesto Interno Fijo ($)</label>
            <input type="number" id="WizardInternalTax" class="form-control" step="0.01" value="0.00" oninput="calculateWizard()" />
        </div>

        <div style="background: rgba(96, 165, 250, 0.1); border: 1px solid var(--accent); padding: 1rem; border-radius: 8px; margin: 2rem 0;">
            <div style="display: flex; justify-content: space-between; font-size: 0.9rem; opacity: 0.8;">
                <span>Subtotal (Costo + IVA)</span>
                <span id="wizardSubtotal">$0,00</span>
            </div>
            <div style="display: flex; justify-content: space-between; font-weight: 700; font-size: 1.2rem; margin-top: 0.5rem; color: var(--accent);">
                <span>Precio Calculado</span>
                <span id="wizardFinal">$0,00</span>
            </div>
        </div>

        <div style="display: flex; gap: 1rem;">
            <button type="button" class="btn-secondary" onclick="closePriceWizard()" style="flex: 1;">Cancelar</button>
            <button type="button" class="btn-primary" onclick="applyWizard()" style="flex: 1;">Aplicar Precio</button>
        </div>
    </div>
</div>

<style>
    .modal-overlay {
        position: fixed; top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0,0,0,0.8); backdrop-filter: blur(10px);
        z-index: 1000; display: flex; align-items: center; justify-content: center;
    }
    .modal-content {
        animation: modalFadeIn 0.3s ease-out;
    }
    @@keyframes modalFadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

@section Scripts {
    <script>
        // Image Preview
        document.getElementById('imageInput').addEventListener('change', function (e) {
            const preview = document.getElementById('imagePreview');
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function (event) {
                    preview.innerHTML = `<img src="${event.target.result}" style="width: 100%; height: 100%; object-fit: cover;" />`;
                }
                reader.readAsDataURL(file);
            }
        });

        // Price Wizard Logic
        function openPriceWizard() {
            document.getElementById('WizardVatRateId').value = document.getElementById('VatRateId').value || "";
            document.getElementById('WizardBaseCost').value = document.getElementById('BaseCost').value || "0.00";
            document.getElementById('WizardProfitMargin').value = document.getElementById('ProfitMargin').value || "0.0";
            document.getElementById('WizardInternalTax').value = document.getElementById('InternalTax').value || "0.00";
            
            calculateWizard();
            document.getElementById('priceWizard').style.display = 'flex';
        }

        function closePriceWizard() {
            document.getElementById('priceWizard').style.display = 'none';
        }

        function calculateWizard() {
            const cost = parseFloat(document.getElementById('WizardBaseCost').value) || 0;
            const margin = parseFloat(document.getElementById('WizardProfitMargin').value) || 0;
            const tax = parseFloat(document.getElementById('WizardInternalTax').value) || 0;
            
            const vatSelect = document.getElementById('WizardVatRateId');
            const vatRate = parseFloat(vatSelect.options[vatSelect.selectedIndex]?.dataset.rate) || 0;

            const costWithIva = cost * (1 + (vatRate / 100));
            const priceWithMargin = costWithIva * (1 + (margin / 100));
            const finalPrice = priceWithMargin + tax;

            document.getElementById('wizardSubtotal').innerText = '$' + costWithIva.toLocaleString('es-AR', { minimumFractionDigits: 2 });
            document.getElementById('wizardFinal').innerText = '$' + finalPrice.toLocaleString('es-AR', { minimumFractionDigits: 2 });
            
            return finalPrice;
        }

        function applyWizard() {
            const finalPrice = calculateWizard();
            document.getElementById('Price').value = finalPrice.toFixed(2);
            
            // Sync hidden fields
            document.getElementById('VatRateId').value = document.getElementById('WizardVatRateId').value;
            document.getElementById('BaseCost').value = document.getElementById('WizardBaseCost').value;
            document.getElementById('ProfitMargin').value = document.getElementById('WizardProfitMargin').value;
            document.getElementById('InternalTax').value = document.getElementById('WizardInternalTax').value;
            
            closePriceWizard();
        }

        document.getElementById('CategoryId').addEventListener('change', function() {
            var categoryId = this.value;
            var subSelect = document.getElementById('SubCategoryId');
            subSelect.innerHTML = '<option value="">Cargando...</option>';
            
            if (!categoryId) {
                subSelect.innerHTML = '<option value="">Primero seleccione rubro</option>';
                return;
            }

            fetch('/SubCategories/GetByCategoryId?categoryId=' + categoryId)
                .then(response => response.json())
                .then(data => {
                    subSelect.innerHTML = '<option value="">Seleccione...</option>';
                    data.forEach(item => {
                        var opt = document.createElement('option');
                        opt.value = item.id;
                        opt.text = item.name;
                        subSelect.add(opt);
                    });
                });
        });

        // Trigger Category change on load if one is selected (validation error case)
        @if (ViewBag.SelectedCategoryId != null && Model.SubCategoryId == null)
        {
            <text>
            document.getElementById('CategoryId').dispatchEvent(new Event('change'));
            </text>
        }
    </script>
}
