@model IEnumerable<GestionQ.Domain.Entities.Product>

@{
    ViewData["Title"] = "Stock de Productos";
}

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; gap: 1rem; flex-wrap: wrap;">
    <h1 class="page-title" style="margin-bottom: 0;">Stock de Productos</h1>
    
    <div style="display: flex; gap: 1rem; flex-grow: 1; justify-content: flex-end; align-items: center;">
        <form asp-action="Index" method="get" style="display: flex; gap: 0.5rem; max-width: 400px; width: 100%;">
            <input type="text" name="q" value="@ViewBag.SearchQuery" class="form-control" placeholder="Buscar por nombre, código o barra..." style="background: rgba(255,255,255,0.05);" />
            <button type="submit" class="btn-secondary">Buscar</button>
            @if (!string.IsNullOrEmpty(ViewBag.SearchQuery as string))
            {
                <a asp-action="Index" class="btn-secondary" style="color: #ef4444; text-decoration: none; padding-top: 0.5rem;">&times;</a>
            }
        </form>
        <a asp-action="PurchaseSuggestions" class="btn-secondary" style="border-color: var(--accent); color: var(--accent);">📊 Sugerencias de Pedido</a>
        <a asp-controller="Purchases" asp-action="Create" class="btn-primary" style="background: var(--accent);">+ Ingresar Compra</a>
        <a asp-action="Import" class="btn-secondary">📥 Importar Excel</a>
        <a asp-action="Create" class="btn-primary">+ Nuevo Producto</a>
    </div>
</div>

@if (TempData["Error"] != null)
{
    <div class="glass-panel" style="background: rgba(239, 68, 68, 0.1); border-color: rgba(239, 68, 68, 0.2); color: #ef4444; margin-bottom: 1rem;">
        @TempData["Error"]
    </div>
}

<div class="glass-panel">
    <table class="table">
        <thead>
            <tr>
                <th>Cód. Int</th>
                <th>Cód. Barras</th>
                <th>Nombre</th>
                <th>Precio</th>
                <th>Stock</th>
                <th style="text-align: right;">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td style="color: var(--accent); font-weight: 600;">@item.InternalCode.ToString("D5")</td>
                    <td style="font-family: monospace; font-size: 1.1rem;">@(item.Barcode ?? "-")</td>
                    <td style="display: flex; align-items: center; gap: 0.75rem;">
                        <div style="width: 40px; height: 40px; border-radius: 8px; overflow: hidden; background: rgba(255,255,255,0.05); flex-shrink: 0; display: flex; align-items: center; justify-content: center;">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" style="width: 100%; height: 100%; object-fit: contain; padding: 2px;" alt="@item.Name" />
                            }
                            else
                            {
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="opacity: 0.3;">
                                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                                    <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
                                    <line x1="12" y1="22.08" x2="12" y2="12"></line>
                                </svg>
                            }
                        </div>
                        <div style="display: flex; flex-direction: column; justify-content: center;">
                            <div style="font-weight: 500; font-size: 1.05rem;">@item.Name</div>
                            <div style="font-size: 0.8rem; color: var(--text-muted); margin-top: 2px; min-height: 18px;">
                                @if (item.SubCategory != null)
                                {
                                    <text>@item.SubCategory?.Category?.Name &bull; @item.SubCategory?.Name</text>
                                }
                            </div>
                            @if (!item.IsActive)
                            {
                                <div><span style="font-size: 0.7rem; background: #ef4444; color: white; padding: 0.1rem 0.4rem; border-radius: 4px; margin-top: 2px; display: inline-block;">Inactivo</span></div>
                            }
                        </div>
                    </td>
                    <td style="font-weight: 700; font-size: 1.1rem; color: #10b981;">$@item.Price.ToString("N2")</td>
                    <td style="font-weight: 600;">
                        <div style="display: flex; flex-direction: column; align-items: flex-start;">
                            <span style="font-size: 1.1rem; color: @(item.Stock <= item.MinimumStock ? "#ef4444" : "#e2e8f0")">@item.Stock un.</span>
                            @if (item.Stock <= item.MinimumStock)
                            {
                                <span style="font-size: 0.7rem; color: #ef4444; font-weight: 500; background: rgba(239, 68, 68, 0.1); padding: 0.1rem 0.4rem; border-radius: 4px; text-align: center; margin-top: 2px;">Stock Crítico (Mín: @item.MinimumStock)</span>
                            }
                        </div>
                    </td>
                    <td style="text-align: right;">
                        <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
                            <a asp-action="Movements" asp-route-id="@item.Id" class="btn-secondary" style="padding: 0.4rem 0.7rem; display: flex; align-items: center; gap: 0.4rem; font-size: 0.85rem;" title="Ficha de Movimientos">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                                Ficha
                            </a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn-primary" style="padding: 0.4rem 0.7rem; display: flex; align-items: center; gap: 0.4rem; font-size: 0.85rem; background: var(--accent);" title="Editar Producto">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                                Editar
                            </a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="delete-product-form" data-name="@item.Name" style="margin: 0;">
                                <button type="submit" class="btn-secondary" style="padding: 0.4rem 0.7rem; display: flex; align-items: center; gap: 0.4rem; font-size: 0.85rem; color: #ef4444; border-color: rgba(239, 68, 68, 0.2);" title="Eliminar Producto">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                                    Eliminar
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.delete-product-form').forEach(form => {
            form.addEventListener('submit', function(e) {
                e.preventDefault();
                const productName = this.getAttribute('data-name');
                
                Swal.fire({
                    title: '¿Eliminar producto?',
                    html: `¿Está seguro que desea eliminar el artículo <b>${productName}</b>?`,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#ef4444',
                    cancelButtonColor: '#4b5563',
                    confirmButtonText: 'Sí, eliminar',
                    cancelButtonText: 'Cancelar',
                    background: '#1e293b',
                    color: '#f8fafc'
                }).then((result) => {
                    if (result.isConfirmed) {
                        this.submit();
                    }
                });
            });
        });
    </script>
}
