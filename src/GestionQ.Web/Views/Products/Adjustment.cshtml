@model GestionQ.Domain.Entities.Product

@{
    ViewData["Title"] = "Ajuste de Stock";
}

<h1 class="page-title">Ajuste de Stock</h1>

<div class="glass-panel" style="max-width: 500px;">
    <div style="margin-bottom: 1.5rem;">
        <label style="opacity: 0.6; font-size: 0.8rem;">Producto</label>
        <div style="font-size: 1.25rem; font-weight: 600;">@Model.Name</div>
        <div style="font-size: 0.9rem; opacity: 0.7;">Stock Actual: <strong>@Model.Stock</strong></div>
    </div>

    <form asp-action="Adjustment" method="post">
        <input type="hidden" name="id" value="@Model.Id" />
        
        <div class="form-group">
            <label class="control-label">Cantidad a ajustar</label>
            <input type="number" name="quantity" class="form-control" step="0.01" required placeholder="Ej: 10 para sumar, -5 para restar" />
            <span class="text-muted" style="font-size: 0.75rem;">Use valores negativos para descontar stock.</span>
        </div>

        <div class="form-group">
            <label class="control-label">Motivo / Concepto</label>
            <input type="text" name="concept" class="form-control" required placeholder="Ej: Rotura, Vencimiento, Inventario Inicial" />
        </div>

        <div style="margin-top: 2rem; display: flex; gap: 1rem;">
            <button type="submit" class="btn-primary" style="flex: 1;">Confirmar Ajuste</button>
            <a asp-action="Movements" asp-route-id="@Model.Id" class="btn-secondary" style="flex: 1; text-align: center;">Cancelar</a>
        </div>
    </form>
</div>
