@model IEnumerable<GestionQ.Domain.Entities.StockMovement>

@{
    var product = ViewBag.Product as GestionQ.Domain.Entities.Product;
    ViewData["Title"] = $"Ficha de Stock - {product?.Name}";
}

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <div>
        <h1 class="page-title" style="margin-bottom: 0.25rem;">Ficha de Stock</h1>
        <p style="opacity: 0.7;">Historial de movimientos para: <span style="color: var(--accent); font-weight: 600;">@product?.Name</span></p>
    </div>
    <div style="text-align: right;">
        <div style="font-size: 0.8rem; opacity: 0.6;">Stock Actual</div>
        <div style="font-size: 2rem; font-weight: 700; color: var(--accent);">@product?.Stock</div>
    </div>
</div>

<div class="glass-panel">
    <table class="table">
        <thead>
            <tr>
                <th>Fecha</th>
                <th>Concepto / Referencia</th>
                <th>Tipo</th>
                <th style="text-align: center;">Anterior</th>
                <th style="text-align: center;">Cantidad</th>
                <th style="text-align: center;">Nuevo Stock</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var m in Model)
            {
                <tr>
                    <td style="opacity: 0.7;">@m.Date.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@m.Concept</td>
                    <td>
                        @{
                            string badgeClass = m.Quantity >= 0 ? "success" : "danger";
                        }
                        <span class="badge badge-@badgeClass">@m.Type.ToString()</span>
                    </td>
                    <td style="text-align: center; opacity: 0.7;">@m.PreviousStock</td>
                    <td style="text-align: center; font-weight: 700; color: @(m.Quantity >= 0 ? "#10b981" : "#ef4444")">
                        @(m.Quantity >= 0 ? "+" : "")@m.Quantity
                    </td>
                    <td style="text-align: center; font-weight: 700;">@m.NewStock</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div style="margin-top: 1.5rem;">
    <a asp-action="Index" class="btn-secondary">Volver al Stock</a>
    <a asp-action="Adjustment" asp-route-id="@product?.Id" class="btn-primary" style="background: var(--accent);">Realizar Ajuste</a>
</div>

<style>
    .badge-success { background: rgba(16, 185, 129, 0.1); color: #10b981; }
    .badge-danger { background: rgba(239, 68, 68, 0.1); color: #ef4444; }
    .badge { padding: 0.25rem 0.5rem; border-radius: 6px; font-size: 0.75rem; font-weight: 600; }
</style>
