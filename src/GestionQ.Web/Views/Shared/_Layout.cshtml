@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Hosting
@using GestionQ.Domain.Constants
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@inject Microsoft.AspNetCore.Authorization.IAuthorizationService AuthorizationService
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @(Configuration["CompanyInfo:FantasyName"] ?? Configuration["CompanyInfo:Name"] ?? "GestionQ")</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@sweetalert2/theme-dark@5/dark.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@@11/dist/sweetalert2.min.js"></script>
</head>

<body>
    <script>
        (function () {
            if (localStorage.getItem('sidebarCollapsed') === 'true') {
                document.body.classList.add('sidebar-collapsed');
            }
        })();
    </script>
    @if (SignInManager.IsSignedIn(User))
    {
        <!-- Botón para Colapsar/Expandir la Barra Lateral -->
        <button type="button" id="sidebarCollapseBtn" class="sidebar-toggle-btn" onclick="toggleSidebar()">
            <i id="sidebarToggleIcon" class="fa-solid fa-angle-left"></i>
        </button>

        <!-- Sidebar -->
        <nav class="sidebar">
            <a asp-controller="Home" asp-action="Index" class="brand">
                @{
                    var logoPath = System.IO.Path.Combine(Env.WebRootPath, "images", "logo.png");
                    var hasLogo = System.IO.File.Exists(logoPath);
                }
                @if (hasLogo)
                {
                    <img src="~/images/logo.png?v=@DateTime.Now.Ticks" style="max-height: 45px; margin-right: 10px;"
                        alt="Logo" />
                    <span>@(Configuration["CompanyInfo:FantasyName"] ?? Configuration["CompanyInfo:Name"] ?? "GestionQ")</span>
                }
                else
                {
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"
                        stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
                        <path d="M2 17l10 5 10-5"></path>
                        <path d="M2 12l10 5 10-5"></path>
                    </svg>
                    <span>@(Configuration["CompanyInfo:FantasyName"] ?? Configuration["CompanyInfo:Name"] ?? "GestionQ")</span>
                }
            </a>

            <div
                style="font-size: 0.85rem; color: var(--text-muted); padding: 0.5rem 1rem; margin-top: -1rem; margin-bottom: 2rem; border-bottom: 1px solid var(--border); padding-bottom: 1rem;">
                Usuario: <br /><strong style="color: white;">@UserManager.GetUserName(User)</strong>
                <form asp-controller="Account" asp-action="Logout" method="post" style="margin-top: 0.5rem;">
                    <button type="submit"
                        style="background:none; border:none; color:#ef4444; padding:0; cursor:pointer; font-size: 0.8rem; text-decoration: underline;">
                        Cerrar Sesión
                    </button>
                </form>
            </div>

            <ul class="nav-links">
                <li>
                    <a asp-controller="Home" asp-action="Index">
                        <i class="fa-solid fa-chart-line"></i> Dashboard
                    </a>
                </li>
                @if (User.IsInRole("Admin") || User.HasClaim("Permission", Permissions.Sales.View))
                {
                <li>
                    <a asp-controller="Sales" asp-action="Index" style="font-weight: 600;">
                        <i class="fa-solid fa-cart-shopping"></i> Ventas
                    </a>
                </li>
                }
                @if (User.IsInRole("Admin") || User.HasClaim("Permission", Permissions.CashRegisters.View))
                {
                <li>
                    <a asp-controller="CashRegisters" asp-action="Index" style="color: #fbbf24; font-weight: 600;">
                        <i class="fa-solid fa-cash-register"></i> Caja / Turno
                    </a>
                </li>
                }
                @if (User.IsInRole("Admin") || User.HasClaim("Permission", Permissions.Customers.View))
                {
                <li>
                    <a asp-controller="Customers" asp-action="Index">
                        <i class="fa-solid fa-users"></i> Cuentas Corrientes
                    </a>
                </li>
                }
                @if (User.IsInRole("Admin") || User.HasClaim("Permission", Permissions.Products.View))
                {
                <li>
                    <a asp-controller="Products" asp-action="Index">
                        <i class="fa-solid fa-box"></i> Stock (Productos)
                    </a>
                </li>
                <li>
                    <a asp-controller="Labels" asp-action="Index" style="color: #ec4899;">
                        <i class="fa-solid fa-barcode"></i> Imprimir Etiquetas
                    </a>
                </li>
                }
                @if (User.IsInRole("Admin") || User.HasClaim("Permission", Permissions.Config.View))
                {
                <li>
                    <a asp-controller="Prices" asp-action="Index" style="color: #60a5fa;">
                        <i class="fa-solid fa-tags"></i> Gestión de Precios
                    </a>
                </li>
                <li>
                    <a asp-controller="Scale" asp-action="Index" style="color: #f59e0b;">
                        <i class="fa-solid fa-scale-balanced"></i> Envío Balanza
                    </a>
                </li>
                }
                @if (User.IsInRole("Admin") || User.HasClaim("Permission", Permissions.Promotions.View))
                {
                <li>
                    <a asp-controller="Promotions" asp-action="Index" style="color: #10b981;">
                        <i class="fa-solid fa-percent"></i> Promociones
                    </a>
                </li>
                }
                @if (User.IsInRole("Admin") || User.HasClaim("Permission", Permissions.Purchases.View))
                {
                    <li>
                        <a asp-controller="Purchases" asp-action="Index" style="color: #60a5fa;">
                            <i class="fa-solid fa-truck-ramp-box"></i> Compras (Ingreso)
                        </a>
                    </li>
                }
                @if (User.IsInRole("Admin") || User.HasClaim("Permission", Permissions.Statistics.View))
                {
                <li>
                    <a asp-controller="Statistics" asp-action="Index" style="color: #a855f7; font-weight: 600;">
                        <i class="fa-solid fa-chart-pie"></i> Estadísticas
                    </a>
                </li>
                }
                @if (User.IsInRole("Admin") || User.HasClaim("Permission", Permissions.ElectronicInvoices.View))
                {

                <li>
                    <a asp-controller="ElectronicInvoices" asp-action="Spool" style="color: #34d399; font-weight: 600;">
                        <i class="fa-solid fa-print"></i> Spool Fiscal
                    </a>
                </li>
                }
                @if (User.IsInRole("Admin") || User.HasClaim("Permission", Permissions.Config.View))
                {
                    <li style="margin-top: 1.5rem; border-top: 1px solid var(--border); padding-top: 1.5rem;">
                        <span style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); padding-left: 1rem; margin-bottom: 0.5rem; display: block;">Configuración</span>
                    </li>
                    <li>
                        <a asp-controller="Configuration" asp-action="Index" style="color: #a78bfa; font-weight: 600;">
                            <i class="fa-solid fa-gears"></i> Ajustes Generales
                        </a>
                    </li>
                }
            </ul>
        </nav>

        <!-- Main Content -->
        <main class="main-content">
            @RenderBody()
        </main>
    }
    else
    {
        <main style="display: flex; align-items: center; justify-content: center; height: 100vh; width: 100%;">
            @RenderBody()
        </main>
    }

    @if (TempData["Message"] != null)
    {
        <script>
            Swal.fire({
                icon: 'info',
                title: 'Atención',
                text: '@TempData["Message"]',
                confirmButtonColor: '#3b82f6'
            });
        </script>
    }

    <script>
        function toggleSidebar() {
            const body = document.body;
            body.classList.toggle('sidebar-collapsed');
            const isCollapsed = body.classList.contains('sidebar-collapsed');
            localStorage.setItem('sidebarCollapsed', isCollapsed ? 'true' : 'false');
        }

        window.addEventListener('message', function(event) {
            if (event.data && event.data.type === 'PRINT_TICKET') {
                if (window.chrome && window.chrome.webview) {
                    window.chrome.webview.postMessage(event.data.payload);
                }
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
