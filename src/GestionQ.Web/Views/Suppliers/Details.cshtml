@model GestionQ.Domain.Entities.Supplier

@{
    ViewData["Title"] = "Detalle de Proveedor";
}

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <h1 class="page-title" style="margin-bottom: 0;">Detalle de Proveedor</h1>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-primary">Editar</a>
        <a asp-action="Index" class="btn-secondary">Volver al Listado</a>
    </div>
</div>

<div class="glass-panel" style="max-width: 800px;">
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
        <div>
            <div style="margin-bottom: 1.5rem;">
                <label style="display: block; opacity: 0.5; font-size: 0.8rem;">Nombre / Razón Social:</label>
                <span style="font-weight: 600; font-size: 1.2rem; color: var(--accent);">@Model.Name</span>
            </div>

            <div style="margin-bottom: 1.5rem;">
                <label style="display: block; opacity: 0.5; font-size: 0.8rem;">CUIT/CUIL:</label>
                <span style="font-weight: 600;">@(Model.TaxId ?? "-")</span>
            </div>

            <div style="margin-bottom: 1.5rem;">
                <label style="display: block; opacity: 0.5; font-size: 0.8rem;">Condición IVA:</label>
                <span style="font-weight: 600;">@(Model.TaxCondition?.Name ?? "-")</span>
            </div>

            <div style="margin-bottom: 1.5rem;">
                <label style="display: block; opacity: 0.5; font-size: 0.8rem;">Persona de Contacto:</label>
                <span style="font-weight: 600;">@(Model.ContactPerson ?? "-")</span>
            </div>
        </div>

        <div>
            <div style="margin-bottom: 1.5rem;">
                <label style="display: block; opacity: 0.5; font-size: 0.8rem;">Teléfono:</label>
                <span style="font-weight: 600;">@(Model.Phone ?? "-")</span>
            </div>

            <div style="margin-bottom: 1.5rem;">
                <label style="display: block; opacity: 0.5; font-size: 0.8rem;">Email:</label>
                <span style="font-weight: 600;">@(Model.Email ?? "-")</span>
            </div>

            <div style="margin-bottom: 1.5rem;">
                <label style="display: block; opacity: 0.5; font-size: 0.8rem;">Localidad:</label>
                <span style="font-weight: 600;">@(Model.City ?? "-")</span>
            </div>

            <div style="margin-bottom: 1.5rem;">
                <label style="display: block; opacity: 0.5; font-size: 0.8rem;">Dirección:</label>
                <span style="font-weight: 600;">@(Model.Address ?? "-")</span>
            </div>
        </div>
    </div>

    <div style="margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid rgba(255,255,255,0.1);">
        <label style="display: block; opacity: 0.5; font-size: 0.8rem; margin-bottom: 0.5rem;">Estado:</label>
        @if (Model.IsActive)
        {
            <span class="badge" style="background: rgba(16, 185, 129, 0.1); color: #10b981; padding: 0.4rem 1rem; border-radius: 20px; font-weight: 600;">Activo</span>
        }
        else
        {
            <span class="badge" style="background: rgba(239, 68, 68, 0.1); color: #ef4444; padding: 0.4rem 1rem; border-radius: 20px; font-weight: 600;">Inactivo</span>
        }
    </div>
</div>
