        async function confirmCashPayment() {
            const received = parseFloat(document.getElementById('cashAmountReceived').value) || 0;
            const total = parseFloat(document.getElementById('cartTotalRaw').value) || 0;
            const customerId = document.getElementById('customerId').value;
            
            // Determinar ID del método de pago de efectivo
            const pm1Select = document.getElementById('paymentMethod1');
            let cashMethodId = null;
            for (let i = 0; i < pm1Select.options.length; i++) {
                if (pm1Select.options[i].text.toLowerCase().includes('efectivo')) {
                    cashMethodId = pm1Select.options[i].value;
                    break;
                }
            }

            if (!cashMethodId) {
                Swal.fire('Error', 'No se encontró el método de pago Efectivo configurado.', 'error');
                return;
            }

            const finalPaidAmount = Math.min(total, received);
            
            // Cerrar el modal
            document.getElementById('cashModal').style.display = 'none';

            // Ejecutar la venta
            submitFinalSale(customerId, cashMethodId, finalPaidAmount, "", 0, null);
