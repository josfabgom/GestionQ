        function addToCart(id, name, price, stock, quantity = undefined) {
            if (quantity === undefined) {
                quantity = nextQuantity;
                nextQuantity = 1;
                updateMultiplierBadge();
            }
            const existing = cart.find(i => i.productId === id);
            if (existing) {
                if (existing.quantity + quantity > stock) {
                    Swal.fire('Stock Insuficiente', 'No hay más stock disponible de este producto.', 'warning');
                    return;
                }
                existing.quantity += quantity;
                if (existing.quantity <= 0) {
                    removeFromCart(id);
                    showSuccessToast('Quitado: ' + name);
                    return;
                }
            } else {
                if (quantity < 0) {
                    Swal.fire('Operación Inválida', 'No se puede restar un producto que no está en la lista.', 'warning');
                    return;
                }
                if (quantity > stock) {
                    Swal.fire('Stock Insuficiente', 'El stock disponible es menor a lo solicitado.', 'warning');
                    return;
                }
                cart.push({ productId: id, name, price, quantity: quantity, stock });
            }
            
            renderCart();
            updateLastProductBanner(name, quantity, price);
            if (quantity < 0) {
                showSuccessToast('Restado: ' + name);
            } else {
                showSuccessToast('Agregado: ' + name);
            }
        }

        function updateQuantity(id, delta) {
            const item = cart.find(i => i.productId === id);
            if (item) {
                item.quantity += delta;
                if (item.quantity > item.stock) {
                    item.quantity = item.stock;
                    Swal.fire('Stock Límite', 'Has alcanzado el stock disponible.', 'info');
                }
                if (item.quantity <= 0) {
                    removeFromCart(id);
                    showSuccessToast('Quitado: ' + item.name);
                    return;
                }
            }
            renderCart();
            if (delta > 0) {
                showSuccessToast('Agregado: ' + item.name);
            } else {
                showSuccessToast('Restado: ' + item.name);
            }
        }

        function removeFromCart(id) {
            cart = cart.filter(x => x.productId !== id);
            renderCart();
        }

