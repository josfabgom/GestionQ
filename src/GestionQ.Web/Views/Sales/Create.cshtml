        function renderCart() {
            const tbody = document.getElementById('cartTableBody');
            const emptyMsg = document.getElementById('emptyCartMessage');
            const itemCountEl = document.getElementById('itemCount');

            tbody.innerHTML = '';
            let brutoSubtotal = 0;
            let totalPromoDiscounts = 0;
            let count = 0;

            if (cart.length === 0) {
                emptyMsg.style.display = 'block';
            } else {
                emptyMsg.style.display = 'none';
            }

            cart.forEach(item => {
                // Evaluar promociones para este producto
                let promoDiscount = 0;
                let promoName = "";
                
                const applicableRules = promotionRules.filter(r => r.productIds.includes(item.productId));
                
                function getRuleDiscount(rule, cartItem) {
                    let discount = 0;
                    if (rule.type === "Percentage") {
                        discount = cartItem.price * cartItem.quantity * (rule.value / 100);
                    } else if (rule.type === "FixedAmount") {
                        discount = cartItem.quantity * rule.value;
                    } else if (rule.type === "XForY") {
                        if (rule.buyQuantity && rule.payQuantity && cartItem.quantity >= rule.buyQuantity) {
                            const groups = Math.floor(cartItem.quantity / rule.buyQuantity);
                            const freeUnits = groups * (rule.buyQuantity - rule.payQuantity);
                            discount = freeUnits * cartItem.price;
                        }
                    } else if (rule.type === "Volume") {
                        if (rule.buyQuantity && cartItem.quantity >= rule.buyQuantity) {
                            const normalSubtotal = cartItem.quantity * cartItem.price;
                            const promoSubtotal = cartItem.quantity * rule.value;
                            discount = Math.max(0, normalSubtotal - promoSubtotal);
                        }
                    }
                    return Math.min(cartItem.price * cartItem.quantity, discount);
                }

                if (applicableRules.length > 0) {
                    const stackableRules = applicableRules.filter(r => r.isStackable);
                    const nonStackableRules = applicableRules.filter(r => !r.isStackable);

                    let bestDiscount = 0;
                    let bestName = "";

                    // Calcular suma de acumulables
                    if (stackableRules.length > 0) {
                        let stackSum = 0;
                        stackableRules.forEach(r => {
                            stackSum += getRuleDiscount(r, item);
                        });
                        bestDiscount = Math.min(item.price * item.quantity, stackSum);
                        bestName = stackableRules.map(r => r.name).join(" + ");
                    }

                    // Calcular cada no acumulable individual y comparar
                    nonStackableRules.forEach(r => {
                        let d = getRuleDiscount(r, item);
                        if (d > bestDiscount) {
                            bestDiscount = d;
                            bestName = r.name;
                        }
                    });

                    promoDiscount = bestDiscount;
                    promoName = bestName;
                }
                
                promoDiscount = Math.min(item.price * item.quantity, promoDiscount);
                item.promoDiscount = promoDiscount;
                item.promoName = promoName;

                const itemBruto = item.price * item.quantity;
                const itemNeto = Math.max(0, itemBruto - promoDiscount);

                brutoSubtotal += itemBruto;
                totalPromoDiscounts += promoDiscount;
                count += item.quantity;

                let subtotalHtml = "";
                let promoBadgeHtml = "";

                if (promoDiscount > 0) {
                    subtotalHtml = `
                        <div style="text-decoration: line-through; color: var(--text-muted); font-size: 0.85rem; font-family: monospace;">$${itemBruto.toLocaleString('es-AR', {minimumFractionDigits: 2})}</div>
                        <div style="color: #34d399; font-family: monospace; font-weight: bold;">$${itemNeto.toLocaleString('es-AR', {minimumFractionDigits: 2})}</div>
                    `;
                    promoBadgeHtml = `
                        <div style="margin-top: 0.2rem;">
                            <span class="pos-promo-badge"><i class="fa-solid fa-tags"></i> ${promoName} (-$${promoDiscount.toLocaleString('es-AR', {minimumFractionDigits: 2})})</span>
                        </div>
                    `;
                } else {
                    subtotalHtml = `
                        <div style="font-family: monospace; font-weight: bold; color: white;">$${itemBruto.toLocaleString('es-AR', {minimumFractionDigits: 2})}</div>
                    `;
                }

                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td>
                        <div style="font-weight: 700; color: white; font-size: 0.95rem;">${item.name}</div>
                        <div style="font-size: 0.75rem; color: var(--text-muted);">Stock disponible: ${item.stock}</div>
                        ${promoBadgeHtml}
                    </td>
                    <td style="text-align: right; font-family: monospace;">$${item.price.toLocaleString('es-AR', {minimumFractionDigits: 2})}</td>
                    <td style="text-align: center;">
                        <div style="display: flex; align-items: center; justify-content: center; gap: 0.5rem;">
                            <button class="qty-btn" onclick="updateQuantity(${item.productId}, -1)">-</button>
                            <span style="font-weight: 700; min-width: 30px; font-size: 0.95rem;">${item.quantity.toFixed(item.quantity % 1 === 0 ? 0 : 3)}</span>
                            <button class="qty-btn" onclick="updateQuantity(${item.productId}, 1)">+</button>
                        </div>
                    </td>
                    <td style="text-align: right; vertical-align: middle;">${subtotalHtml}</td>
                `;
                tbody.appendChild(tr);
            });

            // Calcular Descuento General (Cliente / Manual)
            const discountPercent = parseFloat(document.getElementById('discountPercentInput').value) || 0;
            const discountAmount = parseFloat(document.getElementById('discountAmountInput').value) || 0;

            let generalDiscount = 0;
            if (discountPercent > 0) {
                generalDiscount = (brutoSubtotal - totalPromoDiscounts) * (discountPercent / 100);
            } else if (discountAmount > 0) {
                // El monto ingresado es el descuento manual extra que se quiere aplicar
                generalDiscount = Math.min(brutoSubtotal - totalPromoDiscounts, discountAmount);
            }

            const totalDiscount = totalPromoDiscounts + generalDiscount;
            const netTotal = Math.max(0, brutoSubtotal - totalDiscount);

            // Calcular descuento por medio de pago
            const pm1Select = document.getElementById('paymentMethod1');
            const pm2Select = document.getElementById('paymentMethod2');
            
            const discountPercent1 = pm1Select && pm1Select.selectedIndex >= 0 ? 
                parseFloat(pm1Select.options[pm1Select.selectedIndex].getAttribute('data-discount')) || 0 : 0;
            const discountPercent2 = pm2Select && pm2Select.selectedIndex >= 0 ? 
                parseFloat(pm2Select.options[pm2Select.selectedIndex].getAttribute('data-discount')) || 0 : 0;

            const isSplitOpen = document.getElementById('splitPaymentPanel').style.display !== 'none';
            let paymentDiscount = 0;

            if (isSplitOpen) {
                const amt1 = parseFloat(document.getElementById('paymentAmount1').value) || 0;
                const amt2 = parseFloat(document.getElementById('paymentAmount2').value) || 0;
                
                paymentDiscount = (amt1 * (discountPercent1 / 100)) + (amt2 * (discountPercent2 / 100));
            } else {
                // Pago total con medio de pago 1
                paymentDiscount = netTotal * (discountPercent1 / 100);
            }

            paymentDiscount = Math.min(netTotal, paymentDiscount);
            const finalTotal = Math.max(0, netTotal - paymentDiscount);

            // Actualizar LED Visor
            document.getElementById('cartTotalGigante').textContent = `$${finalTotal.toLocaleString('es-AR', {minimumFractionDigits: 2})}`;
            document.getElementById('cartTotalRaw').value = finalTotal.toFixed(2);
            document.getElementById('paymentDiscountRaw').value = paymentDiscount.toFixed(2);
            document.getElementById('btnCompleteSale').disabled = cart.length === 0;
            itemCountEl.textContent = count.toFixed(count % 1 === 0 ? 0 : 3);

            // Mostrar u ocultar desglose de visor
            const visorBreakdown = document.getElementById('visorBreakdown');
            const totalAllDiscounts = totalDiscount + paymentDiscount;
            if (totalAllDiscounts > 0) {
                visorBreakdown.style.display = 'block';
                document.getElementById('visorSubtotal').textContent = `$${brutoSubtotal.toLocaleString('es-AR', {minimumFractionDigits: 2})}`;
                
                const visorPromoRow = document.getElementById('visorPromoRow');
                if (totalPromoDiscounts > 0) {
                    visorPromoRow.style.display = 'block';
                    document.getElementById('visorPromo').textContent = `-$${totalPromoDiscounts.toLocaleString('es-AR', {minimumFractionDigits: 2})}`;
                } else {
                    visorPromoRow.style.display = 'none';
                }

                const visorDescRow = document.getElementById('visorDescRow');
                if (generalDiscount > 0) {
                    visorDescRow.style.display = 'block';
                    document.getElementById('visorDesc').textContent = `-$${generalDiscount.toLocaleString('es-AR', {minimumFractionDigits: 2})}`;
                } else {
                    visorDescRow.style.display = 'none';
                }

                const visorPayDescRow = document.getElementById('visorPayDescRow');
                if (paymentDiscount > 0) {
                    visorPayDescRow.style.display = 'block';
                    document.getElementById('visorPayDesc').textContent = `-$${paymentDiscount.toLocaleString('es-AR', {minimumFractionDigits: 2})}`;
                } else {
                    visorPayDescRow.style.display = 'none';
                }
            } else {
                visorBreakdown.style.display = 'none';
            }

            calculateDifference();
        }

        async function completeSale() {
            if (cart.length === 0) return;

            const customerId = document.getElementById('customerId').value;
            const pm1 = document.getElementById('paymentMethod1').value;
            const amt1 = parseFloat(document.getElementById('paymentAmount1').value || 0);
            const pm2 = document.getElementById('paymentMethod2').value;
            const amt2 = parseFloat(document.getElementById('paymentAmount2').value || 0);
            const totalCart = parseFloat(document.getElementById('cartTotalRaw').value);

            if (amt1 + amt2 < totalCart) {
                if (!customerId) {
                    await Swal.fire({
                        title: 'Pago Insuficiente',
                        text: `Faltan $${(totalCart - (amt1 + amt2)).toFixed(2)}. Para registrar una venta con saldo deudor, debe seleccionar un cliente registrado (Cuenta Corriente).`,
                        icon: 'error',
                        confirmButtonText: 'Entendido'
                    });
                    return;
                } else {
                    const result = await Swal.fire({
                        title: 'Diferencia de Saldo',
                        text: `El pago es menor al total. ¿Deseas cargar el resto ($${(totalCart - (amt1 + amt2)).toFixed(2)}) a la cuenta corriente del cliente?`,
                        icon: 'question',
                        showCancelButton: true,
                        confirmButtonText: 'Sí, cargar saldo',
                        cancelButtonText: 'Cancelar'
                    });
                    if (!result.isConfirmed) return;
                }
            }

            // MERCADO PAGO INTEGRATION
            const pm1Select = document.getElementById('paymentMethod1');
            const isMp = pm1Select.options[pm1Select.selectedIndex]?.text.toLowerCase().includes('mercado pago') ||
                         pm1Select.options[pm1Select.selectedIndex]?.text.toLowerCase().includes('mercadopago');

            if (isMp && amt1 > 0) {
                try {
                    const btn = document.getElementById('btnCompleteSale');
                    btn.disabled = true;
                    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Conectando con MP...';

                    const selectedText = pm1Select.options[pm1Select.selectedIndex]?.text.toLowerCase() || '';
                    const mpMethod = selectedText.includes('point') ? 'POINT' : 'QR';

                    const response = await fetch('/api/MercadoPago/create-order', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ 
                            amount: amt1, 
                            pointOfSaleId: currentPointOfSaleId,
                            method: mpMethod
                        })
                    });

                    const data = await response.json();
                    if (!data.success) {
                        btn.disabled = false;
                        btn.innerHTML = '<i class="fa-solid fa-check-double"></i> FINALIZAR VENTA [F12]';
                        Swal.fire('Error MP', data.message, 'error');
                        return;
                    }

                    // Mostrar Modal
                    document.getElementById('mpModal').style.display = 'flex';
                    if (data.method === 'QR') {
                        document.getElementById('mpModalQr').style.display = 'block';
                        document.getElementById('mpModalPoint').style.display = 'none';
                        document.getElementById('mpQrImage').src = 'https://api.qrserver.com/v1/create-qr-code/?size=250x250&data=' + encodeURIComponent(data.qrData);
                    } else {
                        document.getElementById('mpModalQr').style.display = 'none';
                        document.getElementById('mpModalPoint').style.display = 'block';
                    }

                    // Polling
                    mpPollingInterval = setInterval(async () => {
                        try {
                             const statusRes = await fetch(`/api/MercadoPago/check-status/${data.reference}?pointOfSaleId=${currentPointOfSaleId}`);
                             const statusData = await statusRes.json();

                            if (statusData.isPaid) {
                                clearInterval(mpPollingInterval);
                                document.getElementById('mpModal').style.display = 'none';

                                Swal.fire({
                                    icon: 'success',
                                    title: '¡Pago Acreditado!',
                                    text: 'Registrando la venta...',
                                    showConfirmButton: false,
                                    timer: 1500
                                });

                                submitFinalSale(customerId, pm1, amt1, pm2, amt2, data.reference);
                            } else if (statusData.status === 'rejected' || statusData.status === 'cancelled') {
                                clearInterval(mpPollingInterval);
                                document.getElementById('mpModal').style.display = 'none';
                                btn.disabled = false;
                                btn.innerHTML = '<i class="fa-solid fa-check-double"></i> FINALIZAR VENTA [F12]';
                                Swal.fire('Pago Rechazado', 'El pago fue rechazado o cancelado en Mercado Pago.', 'error');
                            }
                        } catch (e) {
                            // Ignorar errores temporales
                        }
                    }, 5000);

                } catch (err) {
                    console.error(err);
                    Swal.fire('Error', 'Hubo un error al comunicar con el servidor de pagos.', 'error');
                    document.getElementById('btnCompleteSale').disabled = false;
                    document.getElementById('btnCompleteSale').innerHTML = '<i class="fa-solid fa-check-double"></i> FINALIZAR VENTA [F12]';
                }
                return;
            }

            submitFinalSale(customerId, pm1, amt1, pm2, amt2, null);
        }

        function cancelMpPayment() {
            if (mpPollingInterval) clearInterval(mpPollingInterval);
            document.getElementById('mpModal').style.display = 'none';
            document.getElementById('btnCompleteSale').disabled = false;
            document.getElementById('btnCompleteSale').innerHTML = '<i class="fa-solid fa-check-double"></i> FINALIZAR VENTA [F12]';
            Swal.fire('Operación Cancelada', 'Se ha cancelado la espera del pago.', 'info');
        }

        async function submitFinalSale(customerId, pm1, amt1, pm2, amt2, mpReference) {
            const btn = document.getElementById('btnCompleteSale');
            btn.disabled = true;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Registrando...';

            const payments = [];
            if (pm1 && amt1 > 0) payments.push({ paymentMethodId: parseInt(pm1), amount: amt1, transactionReference: mpReference });
            if (pm2 && amt2 > 0) payments.push({ paymentMethodId: parseInt(pm2), amount: amt2 });

            const discountPercent = parseFloat(document.getElementById('discountPercentInput').value) || 0;
            const discountAmountVal = parseFloat(document.getElementById('discountAmountInput').value) || 0;

            let totalPromoDiscounts = 0;
            cart.forEach(item => {
                totalPromoDiscounts += item.promoDiscount || 0;
            });

            const payload = {
                customerId: customerId ? parseInt(customerId) : null,
                discountPercentage: discountPercent,
                discountAmount: discountPercent > 0 ? totalPromoDiscounts : (totalPromoDiscounts + discountAmountVal),
                paymentDiscountAmount: parseFloat(document.getElementById('paymentDiscountRaw').value) || 0,
                items: cart.map(i => ({ 
                    productId: i.productId, 
                    quantity: i.quantity,
                    discountAmount: i.promoDiscount || 0
                })),
                payments: payments
            };

            try {
                const response = await fetch('/Sales/CreateSale', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                if (response.ok) {
                    const saleId = await response.text();

                    const result = await Swal.fire({
                        title: '¡Venta Registrada!',
                        text: 'La venta se ha guardado con éxito. ¿Deseas ver el ticket para imprimir?',
                        icon: 'success',
                        showCancelButton: true,
                        confirmButtonText: 'Ver Ticket / Imprimir',
                        cancelButtonText: 'Nueva Venta',
                        confirmButtonColor: '#10b981',
                        cancelButtonColor: '#3b82f6'
                    });

                    if (result.isConfirmed) {
                        const printWindow = window.open(`/Sales/PrintTicket/${saleId}`, '_blank');
                        if (printWindow) {
                            printWindow.focus();
                        }
                    }

                    window.location.href = '/Sales/Create';
                } else {
                    const err = await response.text();
                    Swal.fire('Error al procesar', err, 'error');
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fa-solid fa-check-double"></i> FINALIZAR VENTA [F12]';
                }
            } catch (err) {
                console.error(err);
                Swal.fire('Error', 'Hubo un problema de conexión al registrar la venta.', 'error');
                btn.disabled = false;
                btn.innerHTML = '<i class="fa-solid fa-check-double"></i> FINALIZAR VENTA [F12]';
            }
        }
    </script>
}
