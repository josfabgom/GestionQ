        function updateLastProductBanner(name, quantity, price) {
            const banner = document.getElementById('lastProductAlert');
            const nameEl = document.getElementById('lastProductName');
            const priceEl = document.getElementById('lastProductPrice');

            if (!banner || !nameEl || !priceEl) return;

            nameEl.textContent = `${quantity.toFixed(quantity % 1 === 0 ? 0 : 3)}x ${name}`;
            priceEl.textContent = `$${(price * quantity).toLocaleString('es-AR', {minimumFractionDigits: 2})}`;

            banner.style.display = 'flex';

            // Efecto Flash: Verde si suma, Rojo si resta
            if (quantity < 0) {
                banner.style.backgroundColor = 'rgba(239, 68, 68, 0.2)';
                banner.style.borderColor = '#ef4444';
                setTimeout(() => {
                    banner.style.backgroundColor = 'rgba(239, 68, 68, 0.05)';
                    banner.style.borderColor = 'rgba(239, 68, 68, 0.35)';
                }, 300);
            } else {
                banner.style.backgroundColor = 'rgba(16, 185, 129, 0.2)';
                banner.style.borderColor = '#10b981';
                setTimeout(() => {
                    banner.style.backgroundColor = 'rgba(16, 185, 129, 0.05)';
                    banner.style.borderColor = 'rgba(16, 185, 129, 0.35)';
                }, 300);
            }
