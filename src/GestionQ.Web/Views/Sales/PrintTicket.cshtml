@model GestionQ.Domain.Entities.Sale
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@functions {
    public string CenterText(string text, int width = 35)
    {
        if (string.IsNullOrEmpty(text)) return "";
        text = text.Trim();
        if (text.Length >= width) return text.Substring(0, width);
        int spaces = (width - text.Length) / 2;
        return text.PadLeft(text.Length + spaces).PadRight(width);
    }

    public string FormatLine(string leftText, string rightText, int width = 35)
    {
        leftText = leftText ?? "";
        rightText = rightText ?? "";
        int spacesNeeded = width - leftText.Length - rightText.Length;
        if (spacesNeeded < 1)
        {
            int maxLeftLen = width - rightText.Length - 2;
            if (maxLeftLen > 0 && leftText.Length > maxLeftLen)
            {
                leftText = leftText.Substring(0, maxLeftLen);
            }
            spacesNeeded = width - leftText.Length - rightText.Length;
            if (spacesNeeded < 1) spacesNeeded = 1;
        }
        return leftText + new string(' ', spacesNeeded) + rightText;
    }
}
@{
    Layout = null;
    var promoDict = ViewBag.PromoNames as Dictionary<int, string>;
    string GetPromoName(int productId, string defaultName)
    {
        if (promoDict != null && promoDict.TryGetValue(productId, out var name))
        {
            return name;
        }
        return defaultName;
    }

    // Generar contenido del ticket de texto plano para impresoras térmicas
    var companyName = Configuration["CompanyInfo:Name"] ?? "GestionQ";
    var fantasyName = Configuration["CompanyInfo:FantasyName"];
    if (string.IsNullOrWhiteSpace(fantasyName)) fantasyName = companyName;
    var companyAddress = Configuration["CompanyInfo:Address"] ?? "";
    var companyPhone = Configuration["CompanyInfo:Phone"] ?? "";
    var companyEmail = Configuration["CompanyInfo:Email"] ?? "";
    var posName = Model.PointOfSale?.Name ?? "General";
    var ticketNo = Model.FormattedTicketNumber;
    var dateStr = Model.Date.ToString("dd/MM/yyyy HH:mm");
    var customerName = Model.Customer?.Name ?? "Consumidor Final";

    var ticketText = new System.Text.StringBuilder();
    ticketText.AppendLine(CenterText("DOCUMENTO NO VALIDO COMO FACTURA"));
    ticketText.AppendLine(new string('-', 35));
    ticketText.AppendLine(CenterText(fantasyName));
    if (fantasyName != companyName) ticketText.AppendLine(CenterText($"de {companyName}"));
    if (!string.IsNullOrEmpty(companyAddress)) ticketText.AppendLine(CenterText(companyAddress));
    if (!string.IsNullOrEmpty(companyPhone)) ticketText.AppendLine(CenterText($"Tel: {companyPhone}"));
    if (!string.IsNullOrEmpty(companyEmail)) ticketText.AppendLine(CenterText(companyEmail));
    ticketText.AppendLine(new string('-', 35));
    ticketText.AppendLine($"Punto de Venta: {posName}");
    ticketText.AppendLine($"Ticket #:       {ticketNo}");
    ticketText.AppendLine($"Fecha:          {dateStr}");
    ticketText.AppendLine($"Cliente:        {customerName}");
    ticketText.AppendLine(new string('-', 35));
    ticketText.AppendLine(FormatLine("Cant Descripcion", "Total", 35));
    ticketText.AppendLine(new string('-', 35));

    foreach (var item in Model.Items)
    {
        var prodName = (!string.IsNullOrEmpty(item.CustomName) ? item.CustomName : (item.Product?.Name ?? "Producto Sin Nombre")).ToUpper();
        string qtyStr = item.Quantity.ToString(item.Quantity % 1 == 0 ? "F0" : "F3");
        string totalStr = $"${(item.UnitPrice * item.Quantity).ToString("N2")}";
        
        string leftText = $"{qtyStr} {prodName}";
        ticketText.AppendLine(FormatLine(leftText, totalStr, 35));
        
        if (item.Quantity != 1)
        {
            ticketText.AppendLine($"  ({qtyStr} x ${item.UnitPrice.ToString("N2")})");
        }
    }
    
    ticketText.AppendLine(new string('-', 35));
    
    var textPromoDiscount = Model.Items.Sum(i => i.DiscountAmount);
    var textGeneralDiscount = Model.DiscountAmount - textPromoDiscount;
    
    if (Model.DiscountAmount > 0 || Model.PaymentDiscountAmount > 0)
    {
        ticketText.AppendLine(FormatLine("Subtotal Bruto:", $"${Model.SubTotal.ToString("N2")}", 35));
        if (textPromoDiscount > 0)
        {
            var promoDiscounts = Model.Items
                .Where(i => i.DiscountAmount > 0)
                .GroupBy(i => GetPromoName(i.ProductId, "Descuento Promoción"))
                .Select(g => new { Name = g.Key, Amount = g.Sum(i => i.DiscountAmount) });

            foreach (var promo in promoDiscounts)
            {
                ticketText.AppendLine(FormatLine($" - {promo.Name}:", $"-${promo.Amount.ToString("N2")}", 35));
            }
        }
        if (textGeneralDiscount > 0)
        {
            ticketText.AppendLine(FormatLine("Desct. General:", $"-${textGeneralDiscount.ToString("N2")}", 35));
        }
        if (Model.PaymentDiscountAmount > 0)
        {
            var discountedMethods = Model.Payments
                .Where(p => p.PaymentMethod != null && p.PaymentMethod.DiscountPercentage > 0)
                .Select(p => $"{p.PaymentMethod.Name} ({p.PaymentMethod.DiscountPercentage:F0}%)");
            var methodNames = string.Join(" / ", discountedMethods);
            if (string.IsNullOrEmpty(methodNames))
            {
                methodNames = "Medio de Pago";
            }
            ticketText.AppendLine(FormatLine($"Desct. {methodNames}:", $"-${Model.PaymentDiscountAmount.ToString("N2")}", 35));
        }
        ticketText.AppendLine(new string('-', 35));
    }
    
    ticketText.AppendLine(FormatLine("TOTAL NETO:", $"${Model.TotalAmount.ToString("N2")}", 35));
    ticketText.AppendLine();
    ticketText.AppendLine("PAGOS:");
    foreach (var p in Model.Payments)
    {
        ticketText.AppendLine(FormatLine($" - {p.PaymentMethod?.Name ?? "Otro"}:", $"${p.Amount.ToString("N2")}", 35));
    }
    
    decimal totalPaymentsText = Model.Payments.Sum(p => p.Amount);
    if (totalPaymentsText > Model.TotalAmount)
    {
        ticketText.AppendLine(FormatLine("VUELTO:", $"${(totalPaymentsText - Model.TotalAmount).ToString("N2")}", 35));
    }

    ticketText.AppendLine(new string('-', 35));
    ticketText.AppendLine(CenterText("DOCUMENTO NO VALIDO COMO FACTURA", 35));
    ticketText.AppendLine(CenterText("*** GRACIAS POR SU COMPRA ***", 35));
    ticketText.AppendLine(CenterText(companyName, 35));
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Ticket de Venta #@Model.FormattedTicketNumber</title>
    <style>
        @@page {
            margin: 0;
            size: 80mm auto;
        }

        body {
            font-family: 'Courier New', Courier, monospace;
            width: 100%;
            max-width: 80mm;
            margin: 0;
            padding: 5mm;
            color: #000;
            background: #fff;
            font-size: 12px;
        }

        .header {
            text-align: center;
            margin-bottom: 5mm;
            border-bottom: 1px dashed #000;
            padding-bottom: 2mm;
        }

        .header h1 {
            font-size: 18px;
            margin: 0 0 2mm 0;
            text-transform: uppercase;
        }

        .header p {
            margin: 1mm 0;
            line-height: 1.2;
        }

        .info {
            margin-bottom: 3mm;
        }

        .info p {
            margin: 1mm 0;
        }

        .table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 3mm;
        }

        .table th {
            text-align: left;
            border-bottom: 1px solid #000;
            padding: 1mm 0;
        }

        .table td {
            padding: 1mm 0;
            vertical-align: top;
        }

        .text-right {
            text-align: right;
        }

        .totals {
            border-top: 1px dashed #000;
            padding-top: 2mm;
            margin-bottom: 5mm;
        }

        .totals div {
            display: flex;
            justify-content: space-between;
            margin-bottom: 1mm;
        }

        .total-row {
            font-size: 16px;
            font-weight: bold;
        }

        .footer {
            text-align: center;
            font-size: 10px;
            margin-top: 5mm;
            border-top: 1px dashed #000;
            padding-top: 2mm;
        }

        .text-receipt-container {
            display: none;
            width: 100%;
            margin: 0;
            padding: 0 5mm;
            background-color: #fff;
            box-sizing: border-box;
        }

        .text-receipt {
            font-family: 'Courier New', Courier, monospace;
            font-size: 11px;
            line-height: 1.2;
            margin: 0;
            white-space: pre;
            overflow: hidden;
            color: #000000 !important;
            font-weight: bold !important;
            text-rendering: optimizeSpeed;
        }

        @@media print {
            .no-print {
                display: none !important;
            }
            #ticket-content {
                display: none !important;
            }
            body {
            width: 100% !important;
            max-width: 80mm !important;
            padding: 0 !important;
            margin: 0 auto !important;
            background: #fff;
            font-size: 11px !important;
            color: #000000 !important;
            font-weight: bold !important;
        }
            .text-receipt-container {
                display: block !important;
            }
        }
    </style>
</head>
<body>
    <div class="no-print" style="margin-bottom: 20px; text-align: center;">
        <button onclick="window.print()" style="padding: 10px 20px; cursor: pointer; background: #10b981; color: white; border: none; border-radius: 5px; font-weight: bold;">IMPRIMIR TICKET</button>
        <button onclick="generatePDF()" style="padding: 10px 20px; cursor: pointer; background: #3b82f6; color: white; border: none; border-radius: 5px; font-weight: bold; margin-left: 10px;">DESCARGAR PDF</button>
        <button onclick="window.close()" style="padding: 10px 20px; cursor: pointer; background: #64748b; color: white; border: none; border-radius: 5px; font-weight: bold; margin-left: 10px;">CERRAR</button>
    </div>

    <div id="ticket-content">
        <div style="text-align: center; font-weight: bold; border: 1px solid #000; padding: 2mm; margin-bottom: 3mm; text-transform: uppercase;">
            Documento No Válido como Factura
        </div>

        <div class="header">
            <h1>@fantasyName</h1>
            @if (fantasyName != companyName)
            {
                <div style="font-size: 0.8em; margin-top: -5px; margin-bottom: 5px;">de @companyName</div>
            }
            @if (!string.IsNullOrEmpty(companyAddress))
            {
                <p>@companyAddress</p>
            }
            @if (!string.IsNullOrEmpty(companyPhone))
            {
                <p>Tel: @companyPhone</p>
            }
            @if (!string.IsNullOrEmpty(companyEmail))
            {
                <p>@companyEmail</p>
            }
        </div>

        <div class="info">
            <p><strong>Punto de Venta:</strong> @(Model.PointOfSale?.Name ?? "General")</p>
            <p><strong>Ticket #:</strong> @Model.FormattedTicketNumber</p>
            <p><strong>Fecha:</strong> @Model.Date.ToString("dd/MM/yyyy HH:mm")</p>
            <p><strong>Cliente:</strong> @(Model.Customer?.Name ?? "Consumidor Final")</p>
        </div>

        <table class="table">
            <thead>
                <tr>
                    <th style="width: 50%;">Desc.</th>
                    <th style="width: 15%;" class="text-right">Cant.</th>
                    <th style="width: 35%;" class="text-right">Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>
                            @((!string.IsNullOrEmpty(item.CustomName) ? item.CustomName : (item.Product?.Name ?? "Producto Sin Nombre")).ToUpper())
                        </td>
                        <td class="text-right">@item.Quantity.ToString(item.Quantity % 1 == 0 ? "F0" : "F3")</td>
                        <td class="text-right">
                            <span>$@((item.UnitPrice * item.Quantity).ToString("N2"))</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @{
            var totalPromoDiscount = Model.Items.Sum(i => i.DiscountAmount);
            var generalDiscount = Model.DiscountAmount - totalPromoDiscount;
        }

        <div class="totals">
            @if (Model.DiscountAmount > 0 || Model.PaymentDiscountAmount > 0)
            {
                <div>
                    <span>Subtotal Bruto:</span>
                    <span>$@Model.SubTotal.ToString("N2")</span>
                </div>
                @if (totalPromoDiscount > 0)
                {
                    @* Listar cada descuento promocional individualmente agrupado por nombre *@
                    var promoDiscounts = Model.Items
                        .Where(i => i.DiscountAmount > 0)
                        .GroupBy(i => GetPromoName(i.ProductId, "Descuento Promoción"))
                        .Select(g => new { Name = g.Key, Amount = g.Sum(i => i.DiscountAmount) });

                    @foreach (var promo in promoDiscounts)
                    {
                        <div>
                            <span> - @promo.Name:</span>
                            <span>-$@promo.Amount.ToString("N2")</span>
                        </div>
                    }
                }
                @if (generalDiscount > 0)
                {
                    <div>
                        <span>Desct. General:</span>
                        <span>-$@generalDiscount.ToString("N2")</span>
                    </div>
                }
                @if (Model.PaymentDiscountAmount > 0)
                {
                    var discountedMethods = Model.Payments
                        .Where(p => p.PaymentMethod != null && p.PaymentMethod.DiscountPercentage > 0)
                        .Select(p => $"{p.PaymentMethod.Name} ({p.PaymentMethod.DiscountPercentage:F0}%)");
                    var methodNames = string.Join(" / ", discountedMethods);
                    if (string.IsNullOrEmpty(methodNames))
                    {
                        methodNames = "Medio de Pago";
                    }
                    <div>
                        <span>Desct. @methodNames:</span>
                        <span>-$@Model.PaymentDiscountAmount.ToString("N2")</span>
                    </div>
                }
            }
            <div class="total-row" style="margin-top: 1mm; border-top: 1px solid #000; padding-top: 1mm;">
                <span>TOTAL NETO:</span>
                <span>$@Model.TotalAmount.ToString("N2")</span>
            </div>
            <div style="margin-top: 2mm; font-weight: bold;">
                <span>PAGOS:</span>
            </div>
            @foreach (var p in Model.Payments)
            {
                <div>
                    <span> - @p.PaymentMethod?.Name:</span>
                    <span>$@p.Amount.ToString("N2")</span>
                </div>
            }
            @{
                decimal totalPaymentsHtml = Model.Payments.Sum(p => p.Amount);
                if (totalPaymentsHtml > Model.TotalAmount)
                {
                    <div style="margin-top: 1mm; font-weight: bold;">
                        <span>VUELTO:</span>
                        <span>$@((totalPaymentsHtml - Model.TotalAmount).ToString("N2"))</span>
                    </div>
                }
            }
        </div>

        <div class="footer">
            <p style="font-weight: bold; font-size: 11px;">DOCUMENTO NO VALIDO COMO FACTURA</p>
            <p>*** GRACIAS POR SU COMPRA ***</p>
            <p>@companyName</p>
        </div>
    </div>

    <div class="text-receipt-container">
        <pre class="text-receipt">@ticketText.ToString()</pre>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script>
        function generatePDF() {
            const element = document.getElementById('ticket-content');
            const opt = {
                margin: 0,
                filename: 'Ticket_@(Model.FormattedTicketNumber).pdf',
                image: { type: 'jpeg', quality: 0.98 },
                html2canvas: { scale: 2 },
                jsPDF: { unit: 'mm', format: [80, 297], orientation: 'portrait' }
            };

            // New Promise-based usage:
            html2pdf().set(opt).from(element).save();
        }

        window.onload = function() {
            setTimeout(function() { 
                var ticketContent = document.querySelector('.text-receipt').innerText;
                var payload = JSON.stringify({
                    command: 'print',
                    printerName: '@Html.Raw(Model.PointOfSale?.PrinterName ?? "")',
                    copies: @(Model.PointOfSale?.PrintCopies ?? 1),
                    text: ticketContent
                });

                if (window.parent && window.parent !== window) {
                    window.parent.postMessage({ type: 'PRINT_TICKET', payload: payload }, '*');
                } else if (window.chrome && window.chrome.webview) {
                    window.chrome.webview.postMessage(payload);
                } else {
                    window.print(); 
                }
            }, 500);
        };
    </script>
</body>
</html>
