@model GestionQ.Domain.Entities.Sale
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Ticket de Venta #@Model.Id.ToString("D5")</title>
    <style>
        body {
            font-family: 'Courier New', Courier, monospace;
            width: 80mm;
            margin: 0;
            padding: 5mm;
            color: #000;
            background: #fff;
            font-size: 12px;
        }

        .header {
            text-align: center;
            margin-bottom: 5mm;
            border-bottom: 1px dashed #000;
            padding-bottom: 2mm;
        }

        .header h1 {
            font-size: 18px;
            margin: 0 0 2mm 0;
            text-transform: uppercase;
        }

        .header p {
            margin: 1mm 0;
            line-height: 1.2;
        }

        .info {
            margin-bottom: 3mm;
        }

        .info p {
            margin: 1mm 0;
        }

        .table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 3mm;
        }

        .table th {
            text-align: left;
            border-bottom: 1px solid #000;
            padding: 1mm 0;
        }

        .table td {
            padding: 1mm 0;
            vertical-align: top;
        }

        .text-right {
            text-align: right;
        }

        .totals {
            border-top: 1px dashed #000;
            padding-top: 2mm;
            margin-bottom: 5mm;
        }

        .totals div {
            display: flex;
            justify-content: space-between;
            margin-bottom: 1mm;
        }

        .total-row {
            font-size: 16px;
            font-weight: bold;
        }

        .footer {
            text-align: center;
            font-size: 10px;
            margin-top: 5mm;
            border-top: 1px dashed #000;
            padding-top: 2mm;
        }

        @@media print {
            .no-print {
                display: none;
            }
            body {
                width: 80mm;
                padding: 0;
                margin: 0;
            }
        }
    </style>
</head>
<body>
    <div class="no-print" style="margin-bottom: 20px; text-align: center;">
        <button onclick="window.print()" style="padding: 10px 20px; cursor: pointer; background: #10b981; color: white; border: none; border-radius: 5px; font-weight: bold;">IMPRIMIR TICKET</button>
        <button onclick="generatePDF()" style="padding: 10px 20px; cursor: pointer; background: #3b82f6; color: white; border: none; border-radius: 5px; font-weight: bold; margin-left: 10px;">DESCARGAR PDF</button>
        <button onclick="window.close()" style="padding: 10px 20px; cursor: pointer; background: #64748b; color: white; border: none; border-radius: 5px; font-weight: bold; margin-left: 10px;">CERRAR</button>
    </div>

    <div id="ticket-content">
        <div style="text-align: center; font-weight: bold; border: 1px solid #000; padding: 2mm; margin-bottom: 3mm; text-transform: uppercase;">
            Documento No Válido como Factura
        </div>

        <div class="header">
            <h1>@ViewBag.CompanyName</h1>
            @if (!string.IsNullOrEmpty(ViewBag.CompanyAddress))
            {
                <p>@ViewBag.CompanyAddress</p>
            }
            @if (!string.IsNullOrEmpty(ViewBag.CompanyPhone))
            {
                <p>Tel: @ViewBag.CompanyPhone</p>
            }
            @if (!string.IsNullOrEmpty(ViewBag.CompanyEmail))
            {
                <p>@ViewBag.CompanyEmail</p>
            }
        </div>

        <div class="info">
            <p><strong>Ticket #:</strong> @Model.Id.ToString("D8")</p>
            <p><strong>Fecha:</strong> @Model.Date.ToString("dd/MM/yyyy HH:mm")</p>
            <p><strong>Cliente:</strong> @(Model.Customer?.Name ?? "Consumidor Final")</p>
        </div>

        <table class="table">
            <thead>
                <tr>
                    <th style="width: 50%;">Desc.</th>
                    <th style="width: 15%;" class="text-right">Cant.</th>
                    <th style="width: 35%;" class="text-right">Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.Product?.Name</td>
                        <td class="text-right">@item.Quantity</td>
                        <td class="text-right">$@((item.UnitPrice * item.Quantity).ToString("N2"))</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="totals">
            <div class="total-row">
                <span>TOTAL:</span>
                <span>$@Model.TotalAmount.ToString("N2")</span>
            </div>
            <div style="margin-top: 2mm;">
                <span>PAGOS:</span>
            </div>
            @foreach (var p in Model.Payments)
            {
                <div>
                    <span> - @p.PaymentMethod?.Name:</span>
                    <span>$@p.Amount.ToString("N2")</span>
                </div>
            }
        </div>

        <div class="footer">
            <p style="font-weight: bold; font-size: 11px;">DOCUMENTO NO VALIDO COMO FACTURA</p>
            <p>*** GRACIAS POR SU COMPRA ***</p>
            <p>Software de Gestión - GestionQ</p>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script>
        function generatePDF() {
            const element = document.getElementById('ticket-content');
            const opt = {
                margin: 0,
                filename: 'Ticket_@(Model.Id.ToString("D5")).pdf',
                image: { type: 'jpeg', quality: 0.98 },
                html2canvas: { scale: 2 },
                jsPDF: { unit: 'mm', format: [80, 297], orientation: 'portrait' }
            };

            // New Promise-based usage:
            html2pdf().set(opt).from(element).save();
        }

        window.onload = function() {
            // Optional: Auto-generate PDF or Auto-print
        };
    </script>
</body>
</html>
