@model IEnumerable<GestionQ.Domain.Entities.Sale>

@{
    ViewData["Title"] = "Registro de Ventas";
}

<div style="display: flex; justify-content: space-between; align-items: center;">
    <h1 class="page-title">Historial de Ventas</h1>
    <a asp-action="Create" class="btn-primary">+ Nueva Venta</a>
</div>

<div class="glass-panel" style="margin-bottom: 2rem;">
    <form method="get" asp-action="Index" style="display: flex; gap: 1rem; align-items: flex-end; flex-wrap: wrap;">
        <div class="form-group" style="margin-bottom: 0;">
            <label style="font-size: 0.85rem; margin-bottom: 0.3rem;">Fecha Desde</label>
            <input type="date" name="startDate" value="@ViewBag.StartDate" class="form-control" style="padding: 0.5rem; height: 38px;" />
        </div>
        <div class="form-group" style="margin-bottom: 0;">
            <label style="font-size: 0.85rem; margin-bottom: 0.3rem;">Fecha Hasta</label>
            <input type="date" name="endDate" value="@ViewBag.EndDate" class="form-control" style="padding: 0.5rem; height: 38px;" />
        </div>
        <div class="form-group" style="margin-bottom: 0; min-width: 200px;">
            <label style="font-size: 0.85rem; margin-bottom: 0.3rem;">Cliente</label>
            <input type="text" name="customerName" value="@ViewBag.CustomerName" class="form-control" placeholder="Nombre..." style="padding: 0.5rem; height: 38px;" />
        </div>
        <div class="form-group" style="margin-bottom: 0; min-width: 150px;">
            <label style="font-size: 0.85rem; margin-bottom: 0.3rem;">Nº Comprobante</label>
            <input type="text" name="ticketNumber" value="@ViewBag.TicketNumber" class="form-control" placeholder="Ej: 1077" style="padding: 0.5rem; height: 38px;" />
        </div>
        <div style="display: flex; gap: 0.5rem;">
            <button type="submit" class="btn-primary" style="height: 38px; padding: 0 1.2rem;"><i class="fa-solid fa-search" style="margin-right: 0.3rem;"></i> Buscar</button>
            <a asp-action="Index" class="btn-secondary" style="height: 38px; display: flex; align-items: center; padding: 0 1.2rem;">Limpiar</a>
        </div>
    </form>
</div>

<div class="glass-panel">
    <table class="table">
        <thead>
            <tr>
                <th>Nº Ticket</th>
                <th>Fecha y Hora</th>
                <th>Cliente</th>
                <th>Total Facturado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr style="@(item.IsCancelled ? "opacity: 0.6;" : "")">
                    <td>
                        <span style="@(item.IsCancelled ? "text-decoration: line-through;" : "")">@item.FormattedTicketNumber</span>
                        @if (item.IsCancelled)
                        {
                            <span style="background-color: rgba(239, 68, 68, 0.15); color: #f87171; border: 1px solid rgba(239, 68, 68, 0.4); padding: 2px 8px; border-radius: 4px; font-size: 0.75rem; margin-left: 8px; font-weight: 500; display: inline-block; vertical-align: middle;">Anulada</span>
                        }
                    </td>
                    <td>@item.Date.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@(item.Customer?.Name ?? "Consumidor Final")</td>
                    <td style="font-weight: 600; color: @(item.IsCancelled ? "#9ca3af; text-decoration: line-through;" : "#10b981;")">
                        $@item.TotalAmount.ToString("N2")
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn-secondary">Ver Detalle</a>
                        @if (!item.IsCancelled)
                        {
                            <button type="button" onclick="confirmCancelSale(@item.Id, '@item.FormattedTicketNumber')" class="btn-danger" style="margin-left: 8px; padding: 0.5rem 1rem; font-size: 0.875rem;">Anular</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        function confirmCancelSale(saleId, ticketNumber) {
            Swal.fire({
                title: '¿Confirmar Anulación?',
                text: `¿Estás seguro de que deseas anular la venta #${ticketNumber}? Esta acción devolverá el stock, reembolsará en Mercado Pago si corresponde, y emitirá la Nota de Crédito en AFIP. Esta acción no se puede deshacer.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#6b7280',
                confirmButtonText: 'Sí, Anular Venta',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: 'Procesando...',
                        html: 'Comunicando con Mercado Pago y AFIP, por favor espera...',
                        allowOutsideClick: false,
                        didOpen: () => {
                            Swal.showLoading();
                        }
                    });

                    fetch(`/Sales/CancelSale/${saleId}`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        }
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            Swal.fire(
                                '¡Venta Anulada!',
                                data.message,
                                'success'
                            ).then(() => {
                                location.reload();
                            });
                        } else {
                            Swal.fire(
                                'Error',
                                data.message,
                                'error'
                            );
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        Swal.fire(
                            'Error de Red',
                            'No se pudo comunicar con el servidor para anular la venta.',
                            'error'
                        );
                    });
                }
            });
        }
    </script>
}
