@model IEnumerable<GestionQ.Domain.Entities.PaymentMethod>
@{
    ViewData["Title"] = "Medios de Pago";
}

<div style="display: flex; justify-content: space-between; align-items: center;">
    <h1 class="page-title">Medios de Pago</h1>
    <a asp-action="Create" class="btn-primary">+ Nuevo Medio</a>
</div>

<div class="glass-panel">
    <table class="table">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Descuento (%)</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td style="font-weight: 600;">@item.Name</td>
                    <td style="font-family: monospace;">@item.DiscountPercentage.ToString("N1")%</td>
                    <td>
                        @if (item.IsActive)
                        {
                            <span style="color: #10b981; font-weight: 600;">Habilitado</span>
                        }
                        else
                        {
                            <span style="color: #ef4444; font-weight: 600;">Inactivo</span>
                        }
                    </td>
                    <td>
                        <div style="display: flex; gap: 0.5rem;">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn-secondary">Editar</a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="delete-form" data-name="@item.Name" style="margin: 0;">
                                <button type="submit" class="btn-secondary" style="color: #ef4444; border-color: rgba(239, 68, 68, 0.2);" title="Eliminar Medio de Pago">
                                    Eliminar
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.delete-form').forEach(form => {
            form.addEventListener('submit', function(e) {
                e.preventDefault();
                const itemName = this.getAttribute('data-name');
                
                Swal.fire({
                    title: '¿Eliminar Medio de Pago?',
                    html: `¿Está seguro que desea eliminar el medio de pago <b>${itemName}</b>?<br><br><small style="color: #fca5a5;">Nota: Eliminar un medio de pago que ya ha sido usado en ventas podría afectar el historial.</small>`,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#ef4444',
                    cancelButtonColor: '#4b5563',
                    confirmButtonText: 'Sí, eliminar',
                    cancelButtonText: 'Cancelar',
                    background: '#1e293b',
                    color: '#f8fafc'
                }).then((result) => {
                    if (result.isConfirmed) {
                        this.submit();
                    }
                });
            });
        });
    </script>
}
