@model GestionQ.Domain.Entities.PaymentMethod
@{
    ViewData["Title"] = "Editar Medio de Pago";
}

<h1 class="page-title">Editar Medio de Pago</h1>

<div class="glass-panel" style="max-width: 500px;">
    <form asp-action="Edit">
        <input type="hidden" asp-for="Id" />

        <div class="form-group" style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1.5rem;">
            <input asp-for="IsActive" style="width: 20px; height: 20px;" />
            <label asp-for="IsActive" style="margin: 0; font-weight: 600;">Habilitado</label>
        </div>

        <div class="form-group">
            <label asp-for="Name" class="control-label">Nombre del Medio de Pago</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group" style="margin-top: 1rem;">
            <label asp-for="DiscountPercentage" class="control-label">Porcentaje de Descuento (%)</label>
            <input asp-for="DiscountPercentage" class="form-control" type="number" step="0.1" min="0" max="100" placeholder="Ej: 10" />
            <span asp-validation-for="DiscountPercentage" class="text-danger"></span>
        </div>

        <div class="form-group" style="margin-top: 1.5rem; display: flex; gap: 1rem;">
            <input type="submit" value="Guardar Cambios" class="btn-primary" />
            <a asp-action="Index" class="btn-secondary">Volver</a>
        </div>
    </form>
</div>
