@{
    ViewData["Title"] = "Dashboard";
}

<h1 class="page-title">Bienvenido a GestionQ</h1>

<h2 style="margin-top: 1rem; margin-bottom: 1.5rem;">Acciones Rápidas</h2>

<div class="settings-grid">
    <!-- Nueva Venta -->
    <a asp-controller="Sales" asp-action="Create" class="settings-card">
        <span class="settings-card-icon" style="color: #10b981;">
            <i class="fa-solid fa-cart-arrow-down"></i>
        </span>
        <div class="settings-card-title">Nueva Venta</div>
        <div class="settings-card-desc">Iniciar un nuevo comprobante de venta o facturación.</div>
    </a>

    <!-- Nuevo Producto -->
    <a asp-controller="Products" asp-action="Create" class="settings-card">
        <span class="settings-card-icon" style="color: #3b82f6;">
            <i class="fa-solid fa-box-open"></i>
        </span>
        <div class="settings-card-title">Nuevo Producto</div>
        <div class="settings-card-desc">Dar de alta un nuevo artículo o servicio en el catálogo.</div>
    </a>

    <!-- Nuevo Cliente -->
    <a asp-controller="Customers" asp-action="Create" class="settings-card">
        <span class="settings-card-icon" style="color: #8b5cf6;">
            <i class="fa-solid fa-user-plus"></i>
        </span>
        <div class="settings-card-title">Nuevo Cliente</div>
        <div class="settings-card-desc">Registrar un nuevo cliente para seguimiento y cuenta corriente.</div>
    </a>
</div>
