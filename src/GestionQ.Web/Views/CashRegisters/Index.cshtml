@model IEnumerable<GestionQ.Domain.Entities.CashRegister>

@{
    ViewData["Title"] = "Mis Cajas / Turnos";
}

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <h1 class="page-title">Cajas / Turnos</h1>
    @if (ViewBag.HasOpenRegister)
    {
        <a asp-action="Close" asp-route-id="@ViewBag.OpenRegisterId" class="btn-danger" style="background: #ef4444;">🛒 Cerrar Caja Actual</a>
    }
    else
    {
        <a asp-action="Open" class="btn-primary" style="background: #10b981;">💵 Abrir Nueva Caja</a>
    }
</div>

@if (TempData["Message"] != null)
{
    <div style="background: rgba(239, 68, 68, 0.2); border: 1px solid #ef4444; color: #fca5a5; padding: 1rem; border-radius: 8px; margin-bottom: 1rem;">
        @TempData["Message"]
    </div>
}

<div class="glass-panel">
    <table class="table">
        <thead>
            <tr>
                <th>Usuario</th>
                <th>Apertura</th>
                <th>Cierre</th>
                <th>Saldo Inicial</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.User?.UserName</td>
                    <td>@item.OpeningDate.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@(item.ClosingDate.HasValue ? item.ClosingDate.Value.ToString("dd/MM/yyyy HH:mm") : "-")</td>
                    <td style="font-weight: 600;">$@item.InitialBalance.ToString("N2")</td>
                    <td>
                        @if (item.IsOpen)
                        {
                            <span style="background: rgba(16, 185, 129, 0.2); color: #10b981; padding: 0.2rem 0.5rem; border-radius: 4px; font-weight: 600; font-size: 0.8rem;">ABIERTA</span>
                        }
                        else
                        {
                            <span style="background: rgba(239, 68, 68, 0.2); color: #ef4444; padding: 0.2rem 0.5rem; border-radius: 4px; font-weight: 600; font-size: 0.8rem;">CERRADA</span>
                        }
                    </td>
                    <td style="display: flex; gap: 0.5rem;">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn-secondary" style="font-size: 0.8rem;">Ver Detalle</a>
                        <a asp-action="Print" asp-route-id="@item.Id" class="btn-primary" style="background: #3b82f6; font-size: 0.8rem;"><i class="fa-solid fa-print"></i></a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
