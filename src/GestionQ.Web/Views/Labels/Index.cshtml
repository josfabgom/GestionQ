@{
    ViewData["Title"] = "Impresión de Etiquetas";
}

<div class="glass-panel">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
        <h2 style="margin: 0; display: flex; align-items: center; gap: 0.5rem; color: #ec4899;">
            <i class="fa-solid fa-barcode"></i> Diseño e Impresión de Etiquetas
        </h2>
        <a asp-action="Designer" class="btn-primary" style="background: #8b5cf6; border-color: #8b5cf6; text-decoration: none; padding: 0.5rem 1rem; border-radius: 8px; font-weight: bold;">
            <i class="fa-solid fa-pen-ruler"></i> Diseñar Plantillas
        </a>
    </div>

    
    <div id="pendingLabelsAlert" style="display: none; background: rgba(236, 72, 153, 0.15); border: 1px solid #ec4899; padding: 1rem 1.5rem; border-radius: 8px; margin-bottom: 1.5rem; align-items: center; justify-content: space-between;">
        <div>
            <h4 style="margin: 0; color: #fbcfe8;"><i class="fa-solid fa-bell"></i> Novedades Pendientes</h4>
            <p style="margin: 0.25rem 0 0 0; color: #f472b6; font-size: 0.95rem;">Tienes <strong id="pendingLabelsCount">0</strong> artículo(s) que han modificado su precio o fueron creados recientemente.</p>
        </div>
        <button id="btnAddPending" class="btn-primary" style="background: #ec4899; border-color: #ec4899;">
            <i class="fa-solid fa-plus-circle"></i> Añadirlas a la cola
        </button>
    </div>

    <div class="row" style="display: flex; gap: 1.5rem; flex-wrap: wrap;">
        <!-- Left Panel: Search & Add -->
        <div style="flex: 1; min-width: 350px;">
            <div style="background: rgba(0,0,0,0.2); padding: 1.25rem; border-radius: 12px; border: 1px solid var(--border);">
                <h4 style="margin-top: 0; color: var(--text-muted); font-size: 1.1rem; margin-bottom: 1rem;">Buscar Producto</h4>
                
                <div class="form-group" style="position: relative;">
                    <i class="fa-solid fa-search" style="position: absolute; left: 1rem; top: 1rem; color: #94a3b8;"></i>
                    <input type="text" id="productSearch" class="form-control" placeholder="Escribe el nombre, código o código de barras..." style="padding-left: 2.5rem; height: 3rem;" autocomplete="off" />
                    <div id="searchResults" style="position: absolute; top: 100%; left: 0; width: 100%; background: var(--bg-panel); border: 1px solid var(--border); border-radius: 8px; z-index: 1000; max-height: 250px; overflow-y: auto; display: none; box-shadow: 0 10px 25px rgba(0,0,0,0.5); backdrop-filter: blur(10px);">
                        <!-- Results dynamically populated -->
                    </div>
                </div>

                <hr style="border-color: rgba(255,255,255,0.05); margin: 1.5rem 0;" />
                
                <div id="selectedProductConfig" style="display: none;">
                    <h5 style="color: #60a5fa; margin-bottom: 0.5rem;" id="spName"></h5>
                    <div style="display: flex; gap: 1rem; align-items: center; margin-bottom: 1rem;">
                        <span id="spPrice" style="font-weight: bold; font-size: 1.2rem;"></span>
                        <span id="spCode" style="color: var(--text-muted); font-size: 0.9rem;"></span>
                    </div>

                    <div style="display: flex; gap: 1rem;">
                        <div class="form-group" style="flex: 1;">
                            <label>Cantidad</label>
                            <input type="number" id="labelQty" class="form-control" value="1" min="1" />
                        </div>
                        <div class="form-group" style="flex: 2;">
                            <label>Formato de Etiqueta</label>
                            <select id="labelFormat" class="form-control">
                                <option value="50x35">Estándar Térmica (50x35mm)</option>
                                <option value="80x33">Góndola Térmica (80x33mm)</option>
                                <option value="A4_Sheet_50x35">Hoja A4 (Varias etiquetas 55x35mm)</option>
                                <option value="A4">A4 Completo (Para Ofertas/Carteles)</option>
                                <option value="A4_Half">Media A4 (Cartel Mediano)</option>
                            </select>
                        </div>
                    </div>
                    
                    <button class="btn-primary" id="btnAddQueue" style="width: 100%; margin-top: 1rem;">
                        <i class="fa-solid fa-plus"></i> Añadir a Cola de Impresión
                    </button>
                </div>
            </div>
        </div>

        <!-- Right Panel: Print Queue -->
        <div style="flex: 1.5; min-width: 400px;">
            <div style="background: rgba(0,0,0,0.1); padding: 1.25rem; border-radius: 12px; border: 1px solid var(--border); height: 100%; display: flex; flex-direction: column;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                    <h4 style="margin: 0; color: var(--text-muted); font-size: 1.1rem;">Cola de Impresión (<span id="queueCount">0</span>)</h4>
                    <button class="btn-secondary btn-sm" id="btnClearQueue" style="padding: 0.25rem 0.75rem; font-size: 0.85rem;"><i class="fa-solid fa-trash"></i> Vaciar</button>
                </div>

                <div style="flex: 1; overflow-y: auto; background: rgba(0,0,0,0.2); border-radius: 8px; border: 1px solid rgba(255,255,255,0.05); min-height: 250px;">
                    <table class="table" style="margin-bottom: 0;">
                        <thead>
                            <tr>
                                <th>Producto</th>
                                <th style="text-align: center;">Formato</th>
                                <th style="text-align: center;">Cant.</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="queueTableBody">
                            <tr>
                                <td colspan="4" style="text-align: center; color: var(--text-muted); padding: 2rem;">
                                    No hay etiquetas en la cola. Busca y añade productos.
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div style="margin-top: 1rem;">
                    <form id="printForm" method="post" action="/Labels/PrintPreview">
                        <input type="hidden" name="printQueueJson" id="printQueueJson" value="[]" />
                        <button type="submit" class="btn-primary" id="btnPrint" style="width: 100%; font-size: 1.1rem; padding: 0.75rem; background: #ec4899; border-color: #ec4899;" disabled>
                            <i class="fa-solid fa-print"></i> Generar y Previsualizar Etiquetas
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>

        let pendingProducts = [];

        document.addEventListener('DOMContentLoaded', function() {
            fetch('/Labels/GetPendingLabels')
                .then(res => res.json())
                .then(data => {
                    if (data && data.length > 0) {
                        pendingProducts = data;
                        document.getElementById('pendingLabelsCount').textContent = data.length;
                        document.getElementById('pendingLabelsAlert').style.display = 'flex';
                    }
                });
        });

        document.getElementById('btnAddPending').addEventListener('click', function() {
            if (pendingProducts.length === 0) return;

            // Add all to queue
            pendingProducts.forEach(p => {
                const existing = printQueue.find(q => q.ProductId === p.id && q.Format === '50x35');
                if (existing) {
                    existing.Quantity += 1;
                } else {
                    printQueue.push({
                        ProductId: p.id,
                        ProductName: p.name,
                        Format: '50x35',
                        Quantity: 1
                    });
                }
            });

            renderQueue();

            const productIds = pendingProducts.map(p => p.id);

            // Clear from DB
            fetch('/Labels/ClearPendingStatus', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(productIds)
            }).then(() => {
                document.getElementById('pendingLabelsAlert').style.display = 'none';
                pendingProducts = [];
                Swal.fire({
                    toast: true,
                    position: 'top-end',
                    icon: 'success',
                    title: 'Novedades añadidas a la cola',
                    showConfirmButton: false,
                    timer: 2000
                });
            });
        });

        let printQueue = [];
        let selectedProduct = null;
        let searchTimeout = null;

        let currentFocus = -1;
        const searchInput = document.getElementById('productSearch');
        const searchResults = document.getElementById('searchResults');
        
        searchInput.addEventListener('keydown', function(e) {
            let items = searchResults.getElementsByClassName('search-item');
            if (e.key === "ArrowDown") {
                currentFocus++;
                addActive(items);
            } else if (e.key === "ArrowUp") {
                currentFocus--;
                addActive(items);
            } else if (e.key === "Enter") {
                e.preventDefault();
                if (currentFocus > -1 && items.length > 0) {
                    items[currentFocus].click();
                } else if (items.length > 0) {
                    items[0].click();
                }
            }
        });

        function addActive(items) {
            if (!items || items.length === 0) return false;
            removeActive(items);
            if (currentFocus >= items.length) currentFocus = 0;
            if (currentFocus < 0) currentFocus = (items.length - 1);
            items[currentFocus].style.backgroundColor = 'rgba(255,255,255,0.1)';
        }

        function removeActive(items) {
            for (let i = 0; i < items.length; i++) {
                items[i].style.backgroundColor = '';
            }
        }
        
        searchInput.addEventListener('input', function(e) {
            currentFocus = -1;
            clearTimeout(searchTimeout);
            const q = e.target.value.trim();
            if (q.length < 2) {
                searchResults.style.display = 'none';
                return;
            }

            searchTimeout = setTimeout(() => {
                fetch(`/Products/Search?q=${encodeURIComponent(q)}`)
                    .then(res => res.json())
                    .then(data => {
                        searchResults.innerHTML = '';
                        if (data.length === 0) {
                            searchResults.innerHTML = '<div style="padding: 1rem; color: var(--text-muted); text-align: center;">No se encontraron productos</div>';
                        } else {
                            data.forEach(p => {
                                const div = document.createElement('div');
                                div.style.padding = '0.75rem 1rem';
                                div.style.cursor = 'pointer';
                                div.style.borderBottom = '1px solid var(--border)';
                                div.className = 'search-item';
                                div.innerHTML = `
                                    <div style="font-weight: 600;">${p.name}</div>
                                    <div style="font-size: 0.85rem; color: var(--text-muted); display: flex; justify-content: space-between;">
                                        <span>Cod: ${p.barcode || p.internalCode}</span>
                                        <span style="color: #10b981; font-weight: bold;">$${p.price.toFixed(2)}</span>
                                    </div>
                                `;
                                div.onclick = () => selectProduct(p);
                                div.onmouseover = () => {
                                    currentFocus = Array.from(searchResults.children).indexOf(div);
                                    addActive(searchResults.getElementsByClassName('search-item'));
                                };
                                searchResults.appendChild(div);
                            });
                        }
                        searchResults.style.display = 'block';
                    });
            }, 300);
        });

        // Hide search results on outside click
        document.addEventListener('click', function(e) {
            if (!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
                searchResults.style.display = 'none';
            }
        });

        function selectProduct(p) {
            selectedProduct = p;
            document.getElementById('spName').textContent = p.name;
            document.getElementById('spPrice').textContent = '$' + p.price.toFixed(2);
            document.getElementById('spCode').textContent = p.barcode || p.internalCode;
            
            document.getElementById('selectedProductConfig').style.display = 'block';
            searchResults.style.display = 'none';
            searchInput.value = '';
        }

        document.getElementById('btnAddQueue').addEventListener('click', function() {
            if (!selectedProduct) return;
            
            const qty = parseInt(document.getElementById('labelQty').value) || 1;
            const format = document.getElementById('labelFormat').value;

            // Check if already in queue with same format, then increment qty
            const existing = printQueue.find(q => q.ProductId === selectedProduct.id && q.Format === format);
            if (existing) {
                existing.Quantity += qty;
            } else {
                printQueue.push({
                    ProductId: selectedProduct.id,
                    ProductName: selectedProduct.name,
                    Format: format,
                    Quantity: qty
                });
            }

            renderQueue();
            
            // Reset selection
            selectedProduct = null;
            document.getElementById('selectedProductConfig').style.display = 'none';
            document.getElementById('labelQty').value = 1;
            
            Swal.fire({
                toast: true,
                position: 'top-end',
                icon: 'success',
                title: 'Añadido a la cola',
                showConfirmButton: false,
                timer: 1500
            });
        });

        function removeQueueItem(index) {
            printQueue.splice(index, 1);
            renderQueue();
        }

        document.getElementById('btnClearQueue').addEventListener('click', function() {
            if (printQueue.length === 0) return;
            Swal.fire({
                title: '¿Vaciar la cola?',
                text: "Se eliminarán todas las etiquetas pendientes.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#3b82f6',
                confirmButtonText: 'Sí, vaciar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    printQueue = [];
                    renderQueue();
                }
            });
        });

        function renderQueue() {
            const tbody = document.getElementById('queueTableBody');
            document.getElementById('queueCount').textContent = printQueue.length;
            
            const printInput = document.getElementById('printQueueJson');
            // We map to match the C# model strictly
            printInput.value = JSON.stringify(printQueue.map(q => ({ ProductId: q.ProductId, Quantity: q.Quantity, Format: q.Format })));
            
            const btnPrint = document.getElementById('btnPrint');
            btnPrint.disabled = printQueue.length === 0;

            if (printQueue.length === 0) {
                tbody.innerHTML = `<tr><td colspan="4" style="text-align: center; color: var(--text-muted); padding: 2rem;">No hay etiquetas en la cola. Busca y añade productos.</td></tr>`;
                return;
            }

            tbody.innerHTML = '';
            printQueue.forEach((item, index) => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td style="font-weight: 500;">${item.ProductName}</td>
                    <td style="text-align: center;"><span style="background: rgba(255,255,255,0.1); padding: 0.2rem 0.5rem; border-radius: 4px; font-size: 0.8rem;">${item.Format}</span></td>
                    <td style="text-align: center; font-weight: bold;">${item.Quantity}</td>
                    <td style="text-align: right;">
                        <button type="button" class="btn-danger btn-sm" onclick="removeQueueItem(${index})" style="padding: 0.3rem 0.6rem;"><i class="fa-solid fa-times"></i></button>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }
        
        // Add a small style block for hover effects on search results
        const style = document.createElement('style');
        style.textContent = `
            .search-item:hover {
                background: rgba(59, 130, 246, 0.15);
            }
        `;
        document.head.appendChild(style);
    </script>
}
