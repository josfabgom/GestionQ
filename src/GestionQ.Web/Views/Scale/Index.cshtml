@model IEnumerable<GestionQ.Domain.Entities.Product>

@{
    ViewData["Title"] = "Módulo de Balanza Kretz (JDataGate)";
}

<div class="glass-panel">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div>
            <h1 class="page-title" style="margin-bottom: 0.5rem;">
                <i class="fa-solid fa-scale-balanced" style="color: #f59e0b; margin-right: 10px;"></i>Módulo de Envío a Balanza
            </h1>
            <p style="color: var(--text-muted); margin: 0;">Lista de productos configurados como "Es Pesable" que se exportarán al driver Kretz JDataGate.</p>
        </div>
        <div>
            <a asp-controller="Configuration" asp-action="SystemSettings" class="btn-secondary" style="margin-right: 1rem;">
                <i class="fa-solid fa-gear"></i> Ajustes de Ruta
            </a>
            <form asp-action="ExportCatalog" method="post" style="display: inline; margin-right: 0.5rem;">
                <button type="submit" class="btn-primary" onclick="return confirm('¿Está seguro de exportar todos estos productos al archivo TXT?')">
                    <i class="fa-solid fa-file-export"></i> TXT
                </button>
            </form>
            <form asp-action="ExportItegra" method="post" style="display: inline;">
                <button type="submit" class="btn-primary" style="background: #10b981;" onclick="return confirm('¿Está seguro de exportar para Kretz Itegra (TXT fijo)?')">
                    <i class="fa-solid fa-file-lines"></i> TXT Itegra
                </button>
            </form>
            <button type="submit" form="resendForm" class="btn-secondary" style="margin-left: 0.5rem;" onclick="return confirm('¿Marcar los productos seleccionados como novedad para reenviar?')">
                <i class="fa-solid fa-rotate-right"></i> Marcar Novedad
            </button>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div style="background: rgba(16, 185, 129, 0.2); border: 1px solid #10b981; color: #6ee7b7; padding: 1rem; border-radius: 8px; margin-bottom: 2rem;">
            <i class="fa-solid fa-check-circle"></i> @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div style="background: rgba(239, 68, 68, 0.2); border: 1px solid #ef4444; color: #fca5a5; padding: 1rem; border-radius: 8px; margin-bottom: 2rem;">
            <i class="fa-solid fa-triangle-exclamation"></i> @TempData["ErrorMessage"]
        </div>
    }

    <form id="resendForm" asp-action="MarkToResend" method="post">
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th style="width: 40px; text-align: center;">
                            <input type="checkbox" id="selectAll" />
                        </th>
                        <th>Código Int.</th>
                        <th>Nombre</th>
                        <th>Precio</th>
                        <th>Estado</th>
                        <th>Último Envío</th>
                    </tr>
                </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td style="text-align: center;">
                                <input type="checkbox" name="selectedIds" value="@item.Id" class="chkItem" />
                            </td>
                            <td>@item.InternalCode</td>
                            <td style="font-weight: 500;">@item.Name</td>
                            <td>$ @item.Price.ToString("N2")</td>
                            <td>
                                @if (item.SendToScale)
                                {
                                    <span class="badge" style="background-color: #ef4444; color: white; padding: 0.25rem 0.5rem; border-radius: 4px; font-size: 0.8em;"><i class="fa-solid fa-triangle-exclamation"></i> Novedad</span>
                                }
                                else
                                {
                                    <span class="badge" style="background-color: #10b981; color: white; padding: 0.25rem 0.5rem; border-radius: 4px; font-size: 0.8em;"><i class="fa-solid fa-check"></i> Enviado</span>
                                }
                            </td>
                            <td>
                                @if (item.LastSentToScaleDate.HasValue)
                                {
                                    @item.LastSentToScaleDate.Value.ToString("dd/MM/yyyy HH:mm")
                                }
                                else
                                {
                                    <span style="color: var(--text-muted);">-</span>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" style="text-align: center; color: var(--text-muted); padding: 2rem;">
                            No hay productos pesables configurados en el sistema.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    </form>
</div>

@section Scripts {
    <script>
        document.getElementById('selectAll').addEventListener('change', function () {
            var checkboxes = document.querySelectorAll('.chkItem');
            for (var checkbox of checkboxes) {
                checkbox.checked = this.checked;
            }
        });
    </script>
}
