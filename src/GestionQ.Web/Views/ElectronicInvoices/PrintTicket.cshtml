@model GestionQ.Domain.Entities.ElectronicInvoice
@using System.Text
@using System.Text.Json
@functions {
    public string CenterText(string text, int width = 40)
    {
        if (string.IsNullOrEmpty(text)) return "";
        text = text.Trim();
        if (text.Length >= width) return text.Substring(0, width);
        int leftPadding = (width - text.Length) / 2;
        return new string(' ', leftPadding) + text;
    }

    public string FormatLine(string leftText, string rightText, int width = 40)
    {
        leftText = leftText ?? "";
        rightText = rightText ?? "";
        int spacesNeeded = width - leftText.Length - rightText.Length;
        if (spacesNeeded < 1)
        {
            int maxLeftLen = width - rightText.Length - 3;
            if (maxLeftLen > 0 && leftText.Length > maxLeftLen)
            {
                leftText = leftText.Substring(0, maxLeftLen) + "...";
            }
            spacesNeeded = width - leftText.Length - rightText.Length;
            if (spacesNeeded < 1) spacesNeeded = 1;
        }
        return leftText + new string(' ', spacesNeeded) + rightText;
    }
}
@{
    Layout = null; // No MVC wrapper for printing view
    
    // Generate AFIP QR Code Base64 Data
    var qrObj = new {
        ver = 1,
        fecha = Model.IssueDate.ToString("yyyy-MM-dd"),
        cuit = 30712345678L, // Simulated company CUIT (GestionQ)
        ptoVta = Model.PointOfSaleNumber,
        tipoCmp = Model.InvoiceTypeCode,
        nroCmp = Model.InvoiceNumber,
        importe = (double)Model.TotalAmount,
        moneda = "PES",
        ctz = 1.0,
        tipoDocRec = Model.DocTypeCode,
        nroDocRec = long.TryParse(Model.DocNumber, out var recDoc) ? recDoc : 0L,
        tipoCodAut = "E",
        codAut = long.TryParse(Model.CAE, out var caeVal) ? caeVal : 0L
    };
    
    var jsonString = JsonSerializer.Serialize(qrObj);
    var base64Json = Convert.ToBase64String(Encoding.UTF8.GetBytes(jsonString));
    var afipQrUrl = $"https://www.afip.gob.ar/fe/qr/?p={base64Json}";
    var qrImageUrl = $"https://api.qrserver.com/v1/create-qr-code/?size=150x150&data={Uri.EscapeDataString(afipQrUrl)}";

    // Generar contenido del ticket fiscal en texto plano para impresoras térmicas
    var invoiceText = new StringBuilder();
    invoiceText.AppendLine(CenterText("GestionQ S.A."));
    invoiceText.AppendLine(CenterText("Av. Corrientes 1234, CABA"));
    invoiceText.AppendLine(CenterText("CUIT: 30-71234567-8"));
    invoiceText.AppendLine(CenterText("IVA Responsable Inscripto"));
    invoiceText.AppendLine(CenterText("Inicio Act.: 01/01/2020"));
    invoiceText.AppendLine(new string('-', 40));
    
    invoiceText.AppendLine(CenterText(Model.InvoiceTypeDesc));
    invoiceText.AppendLine(CenterText($"Cod. {Model.InvoiceTypeCode.ToString("D2")}"));
    invoiceText.AppendLine(new string('-', 40));
    
    invoiceText.AppendLine($"Comp. Nro: {Model.PointOfSaleNumber.ToString("D5")}-{Model.InvoiceNumber.ToString("D8")}");
    invoiceText.AppendLine($"Fecha:     {Model.IssueDate.ToString("dd/MM/yyyy HH:mm")}");
    invoiceText.AppendLine(new string('-', 40));
    
    invoiceText.AppendLine($"Cliente:   {Model.CustomerName}");
    invoiceText.AppendLine($"Cond. IVA: {Model.CustomerTaxCondition}");
    string docType = Model.DocTypeCode == 80 ? "CUIT" : (Model.DocTypeCode == 96 ? "DNI" : "Doc");
    invoiceText.AppendLine($"{docType}:      {Model.DocNumber}");
    invoiceText.AppendLine(new string('-', 40));
    
    invoiceText.AppendLine(FormatLine("Cant  Producto", "Total", 40));
    invoiceText.AppendLine(new string('-', 40));
    
    if (Model.Sale != null && Model.Sale.Items.Any())
    {
        foreach (var item in Model.Sale.Items)
        {
            decimal itemTotal = item.Quantity * item.UnitPrice;
            string prodName = (!string.IsNullOrEmpty(item.CustomName) ? item.CustomName : (item.Product?.Name ?? "Producto Genérico")).ToUpper();
            invoiceText.AppendLine(prodName);
            
            string qtyStr = $"  {item.Quantity.ToString("N0")} x ${item.UnitPrice.ToString("N2")}";
            string totalStr = $"${itemTotal.ToString("N2")}";
            invoiceText.AppendLine(FormatLine(qtyStr, totalStr, 40));
        }
    }
    else
    {
        invoiceText.AppendLine("1 x OPERACIÓN GLOBAL");
        invoiceText.AppendLine(FormatLine($"  VENTA #{Model.SaleId}", $"${Model.TotalAmount.ToString("N2")}", 40));
    }
    
    invoiceText.AppendLine(new string('-', 40));
    
    invoiceText.AppendLine(FormatLine("Subtotal Neto:", Model.NetAmount.ToString("C"), 40));
    invoiceText.AppendLine(FormatLine("IVA 21%/10.5%:", Model.VatAmount.ToString("C"), 40));
    if (Model.ExemptAmount > 0)
    {
        invoiceText.AppendLine(FormatLine("Exento:", Model.ExemptAmount.ToString("C"), 40));
    }
    invoiceText.AppendLine(new string('=', 40));
    invoiceText.AppendLine(FormatLine("TOTAL:", Model.TotalAmount.ToString("C"), 40));
    invoiceText.AppendLine(new string('=', 40));
    
    var caeText = new StringBuilder();
    caeText.AppendLine(CenterText($"CAE: {Model.CAE}"));
    caeText.AppendLine(CenterText($"Vto CAE: {Model.CAEExpirationDate.ToString("dd/MM/yyyy")}"));
    caeText.AppendLine();
    caeText.AppendLine(CenterText("Comprobante Autorizado por ARCA"));
    caeText.AppendLine(CenterText("Comprobante Electrónico (v4.0)"));
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ticket - @Model.FormattedVoucherNumber</title>
    <link href="https://fonts.googleapis.com/css2?family=Courier+Prime:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <style>
        body {
            font-family: 'Courier Prime', monospace;
            color: #000;
            margin: 0;
            padding: 0;
            background-color: #f0f0f0;
            font-size: 12px;
            line-height: 1.2;
        }

        .ticket-box {
            width: 80mm;
            max-width: 100%;
            margin: 20px auto;
            background-color: #fff;
            padding: 5mm;
            box-shadow: 0 0 5px rgba(0,0,0,0.2);
        }

        .text-center { text-align: center; }
        .text-right { text-align: right; }
        .text-left { text-align: left; }
        
        .bold { font-weight: bold; }
        .mb-1 { margin-bottom: 5px; }
        .mb-2 { margin-bottom: 10px; }
        .mt-2 { margin-top: 10px; }
        
        .divider {
            border-bottom: 1px dashed #000;
            margin: 5px 0;
        }

        .company-name {
            font-size: 16px;
            font-weight: bold;
            margin-bottom: 5px;
        }

        .ticket-header {
            margin-bottom: 10px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            vertical-align: top;
            padding: 2px 0;
        }

        .items-table th {
            border-bottom: 1px solid #000;
        }

        .qr-container {
            text-align: center;
            margin: 15px 0;
        }

        .qr-container img {
            width: 50mm;
            height: 50mm;
        }

        .no-print-area {
            max-width: 80mm;
            margin: 20px auto;
            text-align: center;
        }

        .btn-print {
            background-color: #2563eb;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 6px;
            font-weight: 600;
            cursor: pointer;
            font-family: sans-serif;
            font-size: 14px;
        }

        .text-receipt-container {
            display: none;
            width: 80mm;
            max-width: 100%;
            margin: 0;
            padding: 0;
            background-color: #fff;
        }

        .text-receipt {
            font-family: 'Courier Prime', 'Courier New', Courier, monospace;
            font-size: 12px;
            line-height: 1.2;
            margin: 0;
            white-space: pre-wrap;
            word-break: break-all;
            color: #000;
        }

        @@media print {
            body {
                background-color: #fff;
                margin: 0 !important;
                padding: 0 !important;
            }
            .ticket-box {
                display: none !important;
            }
            .no-print-area {
                display: none !important;
            }
            .text-receipt-container {
                display: block !important;
            }
        }
    </style>
</head>
<body>

    <div class="no-print-area">
        <button class="btn-print" onclick="window.print()"><i class="bi bi-printer"></i> Imprimir Ticket</button>
    </div>

    <div class="ticket-box">
        <div class="text-center ticket-header">
            <div class="company-name">GestionQ S.A.</div>
            <div>Av. Corrientes 1234, CABA</div>
            <div>CUIT: 30-71234567-8</div>
            <div>IVA Responsable Inscripto</div>
            <div>Inicio Act.: 01/01/2020</div>
        </div>
        
        <div class="divider"></div>

        <div class="text-center bold mb-1">
            @Model.InvoiceTypeDesc
        </div>
        <div class="text-center bold mb-2">
            Cod. @Model.InvoiceTypeCode.ToString("D2")
        </div>

        <div><span class="bold">Comp. Nro:</span> @Model.PointOfSaleNumber.ToString("D5")-@Model.InvoiceNumber.ToString("D8")</div>
        <div><span class="bold">Fecha:</span> @Model.IssueDate.ToString("dd/MM/yyyy HH:mm")</div>

        <div class="divider"></div>

        <div><span class="bold">Cliente:</span> @Model.CustomerName</div>
        <div><span class="bold">Cond. IVA:</span> @Model.CustomerTaxCondition</div>
        <div><span class="bold">Doc:</span> @(Model.DocTypeCode == 80 ? "CUIT" : (Model.DocTypeCode == 96 ? "DNI" : "Doc")) @Model.DocNumber</div>

        <div class="divider"></div>

        <table class="items-table mb-2">
            <thead>
                <tr>
                    <th class="text-left">Cant</th>
                    <th class="text-left">Producto</th>
                    <th class="text-right">Total</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Sale != null && Model.Sale.Items.Any())
                {
                    foreach (var item in Model.Sale.Items)
                    {
                        decimal itemTotal = item.Quantity * item.UnitPrice;
                        <tr>
                            <td class="text-left">@item.Quantity.ToString("N0")</td>
                            <td class="text-left">@((!string.IsNullOrEmpty(item.CustomName) ? item.CustomName : (item.Product?.Name ?? "Producto Genérico")).ToUpper())</td>
                            <td class="text-right">@itemTotal.ToString("N2")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td class="text-left">1</td>
                        <td class="text-left">OP. S/ VENTA #@Model.SaleId</td>
                        <td class="text-right">@Model.TotalAmount.ToString("N2")</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="divider"></div>

        <table style="width: 100%;">
            <tr>
                <td class="bold">Subtotal:</td>
                <td class="text-right">@Model.NetAmount.ToString("C")</td>
            </tr>
            <tr>
                <td class="bold">IVA:</td>
                <td class="text-right">@Model.VatAmount.ToString("C")</td>
            </tr>
            @if (Model.ExemptAmount > 0)
            {
                <tr>
                    <td class="bold">Exento:</td>
                    <td class="text-right">@Model.ExemptAmount.ToString("C")</td>
                </tr>
            }
            <tr>
                <td class="bold" style="font-size: 16px;">TOTAL:</td>
                <td class="text-right bold" style="font-size: 16px;">@Model.TotalAmount.ToString("C")</td>
            </tr>
        </table>

        <div class="divider mt-2"></div>

        <div class="qr-container">
            <img src="@qrImageUrl" alt="QR AFIP" />
        </div>

        <div class="text-center mt-2">
            <div class="bold">CAE: @Model.CAE</div>
            <div>Vto CAE: @Model.CAEExpirationDate.ToString("dd/MM/yyyy")</div>
        </div>

        <div class="text-center mt-2" style="font-size: 10px;">
            Comprobante Autorizado por ARCA<br/>
            Comprobante Electrónico (v4.0)
        </div>
    </div>

    <div class="text-receipt-container">
        <pre class="text-receipt">@invoiceText.ToString()</pre>
        <div style="text-align: center; margin: 10px 0;">
            <img src="@qrImageUrl" alt="QR AFIP" style="width: 45mm; height: 45mm; display: inline-block;" />
        </div>
        <pre class="text-receipt">@caeText.ToString()</pre>
    </div>
</body>
</html>
