@model IEnumerable<GestionQ.Domain.Entities.Product>

@{
    ViewData["Title"] = "Gestión de Precios";
}

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; gap: 1rem; flex-wrap: wrap;">
    <h1 class="page-title" style="margin-bottom: 0;">Gestión de Precios</h1>
    <div style="display: flex; gap: 1rem;">
        <button class="btn-primary" onclick="toggleBulkModal()">Actualización Masiva</button>
    </div>
</div>

<div class="glass-panel" style="margin-bottom: 2rem; padding: 1.5rem;">
    <form asp-action="Index" method="get" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; align-items: end;">
        <div class="form-group" style="margin-bottom: 0;">
            <label class="control-label">Buscar</label>
            <input type="text" name="q" value="@ViewContext.HttpContext.Request.Query["q"]" class="form-control" placeholder="Producto o código..." />
        </div>
        <div class="form-group" style="margin-bottom: 0;">
            <label class="control-label">Rubro</label>
            <select name="categoryId" id="CategoryId" class="form-control" onchange="loadSubCategories(this.value)">
                <option value="">Todos los rubros</option>
                @foreach (var cat in ViewBag.Categories as IEnumerable<GestionQ.Domain.Entities.Category>)
                {
                    <option value="@cat.Id" selected="@(ViewContext.HttpContext.Request.Query["categoryId"] == cat.Id.ToString() ? "selected" : null)">@cat.Name</option>
                }
            </select>
        </div>
        <div class="form-group" style="margin-bottom: 0;">
            <label class="control-label">Subrubro</label>
            <select name="subCategoryId" id="SubCategoryId" class="form-control">
                <option value="">Todos los subrubros</option>
            </select>
        </div>
        <div style="display: flex; gap: 0.5rem;">
            <button type="submit" class="btn-secondary" style="flex: 1;">Filtrar</button>
            <a asp-action="Index" class="btn-secondary" style="color: #ef4444;">&times;</a>
        </div>
    </form>
</div>

<div class="glass-panel">
    <table class="table" id="pricesTable">
        <thead>
            <tr>
                <th>Código</th>
                <th>Producto</th>
                <th>Alícuota IVA</th>
                <th>Costo Base ($)</th>
                <th>Margen (%)</th>
                <th>Imp. Int ($)</th>
                <th style="color: var(--accent);">Precio Final ($)</th>
                <th style="text-align: right;">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in Model)
            {
                var latest = product.PriceHistory.OrderByDescending(p => p.UpdateDate).FirstOrDefault();
                <tr data-id="@product.Id">
                    <td style="opacity: 0.6;">@product.InternalCode</td>
                    <td style="font-weight: 600;">@product.Name</td>
                    <td>
                        <select class="form-control inline-edit vat-input" style="width: 120px;">
                            @foreach (var v in ViewBag.VatRates as IEnumerable<GestionQ.Domain.Entities.VatRate>)
                            {
                                <option value="@v.Id" selected="@(product.VatRateId == v.Id ? "selected" : null)" data-rate="@v.Rate">@v.Name (@v.Rate%)</option>
                            }
                        </select>
                    </td>
                    <td>
                        <input type="number" class="form-control inline-edit cost-input" value="@(latest?.BaseCost.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture))" step="0.01" />
                    </td>
                    <td>
                        <input type="number" class="form-control inline-edit margin-input" value="@(latest?.ProfitMargin.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture))" step="0.1" />
                    </td>
                    <td>
                        <input type="number" class="form-control inline-edit tax-input" value="@(latest?.InternalTax.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture))" step="0.01" />
                    </td>
                    <td>
                        <div class="final-price-display" style="font-weight: 700; color: var(--accent); font-size: 1.1rem;">
                            $@product.Price.ToString("N2")
                        </div>
                    </td>
                    <td style="text-align: right; display: flex; gap: 0.5rem; justify-content: flex-end;">
                        <button class="btn-primary update-btn" style="padding: 0.3rem 0.8rem; font-size: 0.85rem;">Modificar</button>
                        <a asp-action="History" asp-route-id="@product.Id" class="btn-secondary" title="Ver Historial" style="padding: 0.3rem 0.6rem;">📜</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Bulk Update Modal -->
<div id="bulkModal" class="modal-overlay" style="display: none;">
    <div class="glass-panel modal-content" style="max-width: 500px; width: 90%;">
        <h2 class="page-title">Actualización Masiva</h2>
        <form asp-action="BulkUpdate" method="post">
            <div class="form-group">
                <label>Filtro por Rubro (Opcional)</label>
                <select name="categoryId" class="form-control">
                    <option value="">Todos</option>
                    @foreach (var cat in ViewBag.Categories as IEnumerable<GestionQ.Domain.Entities.Category>)
                    {
                        <option value="@cat.Id">@cat.Name</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label>Filtro por Subrubro (Opcional)</label>
                <select name="subCategoryId" class="form-control">
                    <option value="">Todos</option>
                </select>
            </div>
            <div class="form-group">
                <label>¿Qué desea actualizar?</label>
                <select name="target" class="form-control">
                    <option value="cost">Costo Base (+%)</option>
                    <option value="final">Precio Final (+%)</option>
                    <option value="margin">Margen de Ganancia (+ Puntos %)</option>
                </select>
            </div>
            <div class="form-group">
                <label>Porcentaje / Puntos a aplicar</label>
                <input type="number" name="percentage" class="form-control" step="0.1" required placeholder="Ej: 10 para aumentar 10%" />
            </div>
            
            <div style="display: flex; gap: 1rem; margin-top: 2rem;">
                <button type="button" class="btn-secondary" onclick="toggleBulkModal()" style="flex: 1;">Cancelar</button>
                <button type="submit" class="btn-primary" style="flex: 1;">Aplicar Cambios</button>
            </div>
        </form>
    </div>
</div>

<style>
    .inline-edit {
        background: rgba(255,255,255,0.05);
        border: 1px solid transparent;
        padding: 0.3rem 0.5rem;
        width: 100px;
        transition: all 0.2s;
    }
    .inline-edit:focus {
        background: rgba(0,0,0,0.3);
        border-color: var(--accent);
    }
    .modal-overlay {
        position: fixed; top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0,0,0,0.8); backdrop-filter: blur(10px);
        z-index: 1000; display: flex; align-items: center; justify-content: center;
    }
</style>

@section Scripts {
    <script>
        function toggleBulkModal() {
            const modal = document.getElementById('bulkModal');
            modal.style.display = modal.style.display === 'none' ? 'flex' : 'none';
        }

        // Live preview when typing
        document.querySelectorAll('.inline-edit').forEach(input => {
            input.addEventListener('input', function() {
                const row = this.closest('tr');
                calculateRow(row);
            });
        });

        function calculateRow(row) {
            const cost = parseFloat(row.querySelector('.cost-input').value) || 0;
            const margin = parseFloat(row.querySelector('.margin-input').value) || 0;
            const tax = parseFloat(row.querySelector('.tax-input').value) || 0;
            
            const vatSelect = row.querySelector('.vat-input');
            const vatRate = parseFloat(vatSelect.options[vatSelect.selectedIndex]?.dataset.rate) || 0;

            const costWithIva = cost * (1 + (vatRate / 100));
            const priceWithMargin = costWithIva * (1 + (margin / 100));
            const finalPrice = priceWithMargin + tax;

            row.querySelector('.final-price-display').innerText = '$' + finalPrice.toLocaleString('es-AR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }

        // Manual Update Click
        document.querySelectorAll('.update-btn').forEach(btn => {
            btn.addEventListener('click', async function() {
                const row = this.closest('tr');
                const productId = row.dataset.id;
                const cost = row.querySelector('.cost-input').value;
                const margin = row.querySelector('.margin-input').value;
                const tax = row.querySelector('.tax-input').value;
                const vatRateId = row.querySelector('.vat-input').value;
                const btnOriginalText = this.innerText;

                this.disabled = true;
                this.innerText = '...';

                try {
                    const response = await fetch('/Prices/UpdateSingle', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                        body: `productId=${productId}&cost=${cost}&margin=${margin}&tax=${tax}&vatRateId=${vatRateId}`
                    });
                    
                    if (response.ok) {
                        const result = await response.json();
                        this.innerText = 'OK!';
                        this.style.background = '#10b981';
                        setTimeout(() => {
                            this.innerText = btnOriginalText;
                            this.style.background = '';
                            this.disabled = false;
                        }, 1000);
                    }
                } catch (e) {
                    console.error(e);
                    this.innerText = 'Error';
                    this.style.background = '#ef4444';
                    setTimeout(() => {
                        this.innerText = btnOriginalText;
                        this.style.background = '';
                        this.disabled = false;
                    }, 2000);
                }
            });
        });

        async function loadSubCategories(categoryId) {
            const select = document.getElementById('SubCategoryId');
            select.innerHTML = '<option value="">Todos los subrubros</option>';
            if (!categoryId) return;

            const response = await fetch(`/Products/GetSubCategories?categoryId=${categoryId}`);
            const subs = await response.json();
            subs.forEach(s => {
                select.innerHTML += `<option value="${s.id}">${s.name}</option>`;
            });
        }
    </script>
}
