@model GestionQ.Web.Controllers.EditUserRoleViewModel
@{
    ViewData["Title"] = "Editar Rol";
}
<h1 class="page-title">Editar Rol de @Model.Email</h1>

<div class="glass-panel" style="max-width: 400px;">
    <form asp-action="EditRole" method="post">
        <input type="hidden" asp-for="UserId" />
        <div class="form-group">
            <label>Rol Actual</label>
            <input value="@(Model.CurrentRole ?? "Sin rol")" class="form-control" disabled />
        </div>
        <div class="form-group">
            <label asp-for="NewRole">Cambiar Rol A:</label>
            <select asp-for="NewRole" class="form-control">
                <option value="">(Quitar Rol Actual)</option>
                @foreach (var r in ViewBag.Roles as IEnumerable<string>)
                {
                    if (r == Model.CurrentRole)
                    {
                        <option value="@r" selected>@r</option>
                    }
                    else
                    {
                        <option value="@r">@r</option>
                    }
                }
            </select>
        </div>
        <div class="form-group" style="margin-top: 1.5rem; display: flex; gap: 1rem;">
            <button type="submit" class="btn-primary">Guardar Cambios</button>
            <a asp-action="Index" class="btn-secondary">Volver</a>
        </div>
    </form>
</div>
