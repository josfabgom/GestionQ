@model GestionQ.Web.Controllers.CreateUserViewModel
@{
    ViewData["Title"] = "Nuevo Usuario";
}
<h1 class="page-title">Nuevo Usuario</h1>

<div class="glass-panel" style="max-width: 500px;">
    <form asp-action="Create" method="post">
        <div class="form-group">
            <label asp-for="Email">Email / Usuario</label>
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="Password">Contraseña</label>
            <input asp-for="Password" type="password" class="form-control" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="Role">Asignar Rol</label>
            <select asp-for="Role" class="form-control">
                <option value="">Seleccione un Rol (Opcional)</option>
                @foreach (var role in ViewBag.Roles as IEnumerable<string>)
                {
                        <option value="@role">@role</option>
                }
            </select>
        </div>
        <div class="form-group" style="margin-top: 1.5rem; display: flex; gap: 1rem;">
            <button type="submit" class="btn-primary">Registrar Usuario</button>
            <a asp-action="Index" class="btn-secondary">Volver</a>
        </div>
    </form>
</div>
