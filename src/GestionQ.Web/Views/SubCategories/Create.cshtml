@model GestionQ.Domain.Entities.SubCategory

@{
    ViewData["Title"] = "Nuevo Subrubro";
}

<h1 class="page-title">Nuevo Subrubro</h1>

<div class="glass-panel" style="max-width: 500px;">
    <form asp-action="Create">
        <div class="form-group">
            <label asp-for="CategoryId" class="control-label">Rubro</label>
            <select asp-for="CategoryId" class="form-control" asp-items="ViewBag.CategoryId">
                <option value="">Seleccione un Rubro</option>
            </select>
            <span asp-validation-for="CategoryId" class="text-danger"></span>
        </div>
        
        <div class="form-group">
            <label asp-for="Name" class="control-label"></label>
            <input asp-for="Name" class="form-control" placeholder="Ej: Gaseosas, Galletitas..." />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group" style="margin-top: 1.5rem; display: flex; gap: 1rem;">
            <input type="submit" value="Guardar" class="btn-primary" />
            <a asp-action="Index" class="btn-secondary">Volver</a>
        </div>
    </form>
</div>
