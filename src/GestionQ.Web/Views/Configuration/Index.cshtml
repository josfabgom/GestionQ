@{
    ViewData["Title"] = "Configuración del Sistema";
}

<h1 class="page-title">Configuración General</h1>

<p style="color: var(--text-muted); margin-bottom: 2.5rem; max-width: 800px; font-size: 1.05rem;">
    Bienvenido al panel central de configuración. Desde aquí puedes administrar todos los parámetros del sistema, desde conexiones a bases de datos hasta catálogos de rubros y usuarios.
</p>

<div class="settings-grid">
    <!-- Ajustes BD y Logo -->
    <a asp-controller="Configuration" asp-action="SystemSettings" class="settings-card">
        <span class="settings-card-icon" style="color: #a78bfa;">
            <i class="fa-solid fa-gears"></i>
        </span>
        <div class="settings-card-title">Ajustes del Sistema</div>
        <div class="settings-card-desc">Configuración de base de datos SQL Server, identidad de la empresa, contacto y carga de logotipo.</div>
    </a>

    <!-- Configuración Mercado Pago -->
    <a asp-controller="MercadoPagoConfig" asp-action="Index" class="settings-card">
        <span class="settings-card-icon" style="color: #009ee3;">
            <i class="fa-solid fa-handshake"></i>
        </span>
        <div class="settings-card-title">Conf. Mercado Pago</div>
        <div class="settings-card-desc">Administre sus integraciones con Mercado Pago: Códigos QR y terminales Point.</div>
    </a>

    <!-- Auditoría MP -->
    <a asp-controller="MercadoPagoConfig" asp-action="Transactions" class="settings-card">
        <span class="settings-card-icon" style="color: #009ee3;">
            <i class="fa-solid fa-qrcode"></i>
        </span>
        <div class="settings-card-title">Auditoría MP</div>
        <div class="settings-card-desc">Historial y control de todos los cobros aprobados con Mercado Pago y su referencia.</div>
    </a>

    <!-- Terminal POS -->
    <a asp-controller="POSConfig" asp-action="Index" class="settings-card">
        <span class="settings-card-icon" style="color: #10b981;">
            <i class="fa-solid fa-desktop"></i>
        </span>
        <div class="settings-card-title">Configurar Terminal</div>
        <div class="settings-card-desc">Asigne y vincule este navegador web a un Punto de Venta específico para la emisión de comprobantes.</div>
    </a>

    <!-- Puntos de Venta -->
    <a asp-controller="PointsOfSale" asp-action="Index" class="settings-card">
        <span class="settings-card-icon" style="color: #3b82f6;">
            <i class="fa-solid fa-store"></i>
        </span>
        <div class="settings-card-title">Puntos de Venta</div>
        <div class="settings-card-desc">Administrar los Puntos de Venta habilitados en el sistema (cajas físicas, facturación electrónica, etc.).</div>
    </a>

    <!-- Certificados AFIP -->
    <a asp-controller="ElectronicInvoices" asp-action="Certificates" class="settings-card">
        <span class="settings-card-icon" style="color: #8b5cf6;">
            <i class="fa-solid fa-file-signature"></i>
        </span>
        <div class="settings-card-title">Certificados AFIP</div>
        <div class="settings-card-desc">Configure y cargue los certificados digitales (.pfx) necesarios para la emisión de comprobantes en ARCA.</div>
    </a>

    <!-- ABM Usuarios -->
    <a asp-controller="Users" asp-action="Index" class="settings-card">
        <span class="settings-card-icon" style="color: #ec4899;">
            <i class="fa-solid fa-user-gear"></i>
        </span>
        <div class="settings-card-title">ABM Usuarios</div>
        <div class="settings-card-desc">Gestione los accesos al sistema, contraseñas, roles de Administrador o Vendedor y credenciales.</div>
    </a>

    <!-- Roles y Permisos -->
    <a asp-controller="Roles" asp-action="Index" class="settings-card">
        <span class="settings-card-icon" style="color: #fca5a5;">
            <i class="fa-solid fa-user-shield"></i>
        </span>
        <div class="settings-card-title">Roles y Permisos</div>
        <div class="settings-card-desc">Cree roles personalizados y asigne permisos detallados para cada módulo del sistema.</div>
    </a>

    <!-- Proveedores -->
    <a asp-controller="Suppliers" asp-action="Index" class="settings-card">
        <span class="settings-card-icon" style="color: #f59e0b;">
            <i class="fa-solid fa-truck-field"></i>
        </span>
        <div class="settings-card-title">Proveedores</div>
        <div class="settings-card-desc">Listado y administración de proveedores asociados para las compras e ingresos de mercadería.</div>
    </a>

    <!-- Medios de Pago -->
    <a asp-controller="PaymentMethods" asp-action="Index" class="settings-card">
        <span class="settings-card-icon" style="color: #f43f5e;">
            <i class="fa-solid fa-credit-card"></i>
        </span>
        <div class="settings-card-title">Medios de Pago</div>
        <div class="settings-card-desc">Configure los métodos de pago aceptados en caja (Efectivo, Tarjetas, Transferencias, Cuenta Corriente).</div>
    </a>

    <!-- Rubros -->
    <a asp-controller="Categories" asp-action="Index" class="settings-card">
        <span class="settings-card-icon" style="color: #84cc16;">
            <i class="fa-solid fa-folder-open"></i>
        </span>
        <div class="settings-card-title">Rubros</div>
        <div class="settings-card-desc">Categorías principales de productos para ordenar el catálogo y facilitar el control del stock.</div>
    </a>

    <!-- Subrubros -->
    <a asp-controller="SubCategories" asp-action="Index" class="settings-card">
        <span class="settings-card-icon" style="color: #14b8a6;">
            <i class="fa-solid fa-folder-tree"></i>
        </span>
        <div class="settings-card-title">Subrubros</div>
        <div class="settings-card-desc">Subcategorías de productos para una clasificación de inventario aún más detallada.</div>
    </a>

    <!-- Alícuotas de IVA -->
    <a asp-controller="VatRates" asp-action="Index" class="settings-card">
        <span class="settings-card-icon" style="color: #06b6d4;">
            <i class="fa-solid fa-percent"></i>
        </span>
        <div class="settings-card-title">Alícuotas de IVA</div>
        <div class="settings-card-desc">Configuración de las tasas e impuestos del valor agregado (IVA 21%, IVA 10.5%, Exento, etc.).</div>
    </a>

    <!-- Condiciones ante el IVA -->
    <a asp-controller="TaxConditions" asp-action="Index" class="settings-card">
        <span class="settings-card-icon" style="color: #6366f1;">
            <i class="fa-solid fa-building-columns"></i>
        </span>
        <div class="settings-card-title">Condiciones ante el IVA</div>
        <div class="settings-card-desc">Tipos de condiciones impositivas de clientes y proveedores ante organismos públicos (ARCA/AFIP).</div>
    </a>
</div>
