@model GestionQ.Domain.Entities.Category

@{
    ViewData["Title"] = "Nuevo Rubro";
}

<h1 class="page-title">Nuevo Rubro</h1>

<div class="glass-panel" style="max-width: 500px;">
    <form asp-action="Create">
        <div class="form-group">
            <label asp-for="Name" class="control-label"></label>
            <input asp-for="Name" class="form-control" placeholder="Ej: Bebidas, Limpieza..." />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group" style="margin-top: 1.5rem; display: flex; gap: 1rem;">
            <input type="submit" value="Guardar" class="btn-primary" />
            <a asp-action="Index" class="btn-secondary">Volver</a>
        </div>
    </form>
</div>
