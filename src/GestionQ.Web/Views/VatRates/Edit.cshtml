@model GestionQ.Domain.Entities.VatRate

@{
    ViewData["Title"] = "Editar Alícuota de IVA";
}

<h1 class="page-title">Editar Alícuota de IVA (%)</h1>

<div class="glass-panel" style="max-width: 500px;">
    <form asp-action="Edit">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-group">
            <label asp-for="Name" class="control-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Rate" class="control-label"></label>
            <input asp-for="Rate" class="form-control" step="0.01" />
            <span asp-validation-for="Rate" class="text-danger"></span>
        </div>

        <div class="form-group" style="display: flex; align-items: center; gap: 0.5rem; margin-top: 1rem;">
            <input asp-for="IsActive" style="width: 18px; height: 18px;" />
            <label asp-for="IsActive" class="control-label" style="margin: 0;">Activo</label>
        </div>

        <div class="form-group" style="margin-top: 2rem; display: flex; gap: 1rem;">
            <button type="submit" class="btn-primary">Actualizar</button>
            <a asp-action="Index" class="btn-secondary">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
