<Window x:Class="GestionQ.Installer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Instalador de GestionQ" Height="450" Width="600"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Loaded="Window_Loaded">
    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1E88E5" Padding="20,10">
            <TextBlock x:Name="TxtHeader" Text="Instalación de GestionQ" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Row="1" Margin="20">
            
            <!-- Page 1: Welcome -->
            <StackPanel x:Name="PageWelcome" Visibility="Visible">
                <TextBlock Text="Bienvenido al asistente de instalación de GestionQ." FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock Text="Este asistente te guiará paso a paso para instalar el servidor de Punto de Venta, la base de datos SQL y configurar todo lo necesario." TextWrapping="Wrap" Margin="0,0,0,10"/>
                <TextBlock Text="Haz clic en Siguiente para continuar." TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Page 2: Settings -->
            <StackPanel x:Name="PageSettings" Visibility="Collapsed">
                <TextBlock Text="Configuración de Instalación" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock Text="Selecciona la carpeta de destino:" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtInstallPath" Text="C:\GestionQ" FontSize="14" Padding="5"/>
                
                <TextBlock Text="Al instalar, se configurará automáticamente:" FontWeight="Bold" Margin="0,20,0,5"/>
                <TextBlock Text=" - SQL Server Express" Margin="10,2,0,0"/>
                <TextBlock Text=" - Base de Datos local" Margin="10,2,0,0"/>
                <TextBlock Text=" - Servicio de Windows" Margin="10,2,0,0"/>
                <TextBlock Text=" - Reglas de Firewall" Margin="10,2,0,0"/>
            </StackPanel>

            <!-- Page 3: Progress -->
            <StackPanel x:Name="PageProgress" Visibility="Collapsed" VerticalAlignment="Center">
                <TextBlock x:Name="TxtProgressStatus" Text="Preparando instalación..." FontSize="14" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                <ProgressBar x:Name="ProgressBar" Height="20" Minimum="0" Maximum="100" Value="0"/>
                <TextBox x:Name="TxtLog" Height="150" Margin="0,20,0,0" IsReadOnly="True" VerticalScrollBarVisibility="Auto" Background="#EEEEEE" FontFamily="Consolas"/>
            </StackPanel>

            <!-- Page 4: Finished -->
            <StackPanel x:Name="PageFinished" Visibility="Collapsed" VerticalAlignment="Center">
                <TextBlock Text="¡Instalación Completada con Éxito!" FontSize="20" FontWeight="Bold" Foreground="Green" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <TextBlock Text="GestionQ se ha instalado y el servicio ya se encuentra corriendo." TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="Puedes cerrar este instalador." TextWrapping="Wrap" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Page 5: Error -->
            <StackPanel x:Name="PageError" Visibility="Collapsed" VerticalAlignment="Center">
                <TextBlock Text="Ha ocurrido un error durante la instalación." FontSize="18" FontWeight="Bold" Foreground="Red" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock x:Name="TxtErrorMessage" Text="Detalles del error..." TextWrapping="Wrap" Foreground="DarkRed" Margin="0,0,0,10"/>
                <TextBlock Text="Revisa el registro para más detalles o intenta ejecutar el instalador nuevamente." TextWrapping="Wrap" HorizontalAlignment="Center"/>
            </StackPanel>

        </Grid>

        <!-- Footer / Navigation -->
        <Border Grid.Row="2" Background="White" BorderBrush="#DDDDDD" BorderThickness="0,1,0,0" Padding="20,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnBack" Content="&lt; Atrás" Width="90" Height="30" Margin="0,0,10,0" Click="BtnBack_Click"/>
                <Button x:Name="BtnNext" Content="Siguiente &gt;" Width="90" Height="30" Margin="0,0,10,0" Click="BtnNext_Click"/>
                <Button x:Name="BtnCancel" Content="Cancelar" Width="90" Height="30" Click="BtnCancel_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
